NODE_ENV=development
PORT=3000

# Backend API URL (HARUS sama dengan port backend)
API_URL=http://localhost:5000/api

# Session secret (WAJIB ganti dengan random string panjang, generate: openssl rand -hex 64)
SESSION_SECRET=ganti_dengan_random_64_char_minimal_32_karakter_buat_session_aman_x123

# Database (untuk globalSettings & maintenanceCheck yang query langsung)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=uptd_lab
DB_PORT=3306

# Cookie settings
COOKIE_SECURE=false
COOKIE_MAX_AGE_DAYS=7

# Upload limit (MB)
MAX_UPLOAD_SIZE_MB=50
