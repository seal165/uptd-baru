# ==================== ENVIRONMENT ====================
NODE_ENV=development
# Use: production, development

# ==================== SERVER ====================
PORT=3000
# Gunakan port 3000 untuk frontend development

# ==================== BACKEND API ====================
# URL untuk reach backend API
# Development: http://localhost:5000/api
# Production: https://api.your-domain.com
API_URL=http://localhost:5000/api

# ==================== SESSION ====================
# Generate dengan: openssl rand -hex 32
# PENTING! Gunakan string yang berbeda untuk setiap environment!
# JANGAN gunakan value contoh ini untuk production!
SESSION_SECRET=your_session_secret_key_here_must_be_at_least_32_characters_long_1234567890

# ==================== DEPLOYMENT ====================
# Production Settings (uncomment dan set)
# NODE_ENV=production
# PORT=3000
# API_URL=https://api.your-domain.com
# SESSION_SECRET=your_production_session_secret_64_chars_here

# ==================== OPTIONAL: Analytics ====================
# ANALYTICS_ID=your_analytics_id
# Enable tracking untuk analytics

# ==================== OPTIONAL: Security ====================
# ENABLE_CSRF_PROTECTION=true
# ENABLE_XSS_PROTECTION=true
