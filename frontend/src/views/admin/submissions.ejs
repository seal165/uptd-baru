<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body>

    <div class="app-wrapper">
        <%- include('partials/sidebar', { page: 'submissions' }) %>

        <main class="main-content">
            <%- include('partials/top-navbar', { pageTitle: 'Manajemen Pengajuan' }) %>

            <div class="content-body">
                <!-- Data dari backend disimpan di atribut data -->
                <div id="page-data" 
                     data-submissions='<%- JSON.stringify(submissions || []).replace(/'/g, "\\'") %>'
                     data-pagination='<%- JSON.stringify(pagination || {}).replace(/'/g, "\\'") %>'
                     data-filters='<%- JSON.stringify(filters || {}).replace(/'/g, "\\'") %>'
                     style="display: none;"></div>

                <!-- Alert Message -->
                <div id="alertMessage" class="alert" style="display: none;"></div>

                <div class="mb-2">
                    <h5 class="fw-bold">Daftar Pengajuan Masuk</h5>
                    <p class="text-muted mb-0">Kelola dan pantau status pengajuan pengujian laboratorium.</p>
                </div>

                <!-- Custom Style for Filters -->
                
                <!-- Filter dan Search Section -->
                <div class="mb-4">
                    <div class="d-flex align-items-center gap-2 overflow-auto filter-container py-2" style="white-space: nowrap;">
                        <!-- Search -->
                        <div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-3 filter-pill" style="min-width: 200px;">
                            <i class="fas fa-search text-muted me-1" style="font-size: 0.85rem;"></i>
                            <input type="text" class="form-control form-control-sm bg-transparent border-0 shadow-none px-0 py-0 m-0" id="searchInput" placeholder="Cari ID, Perusahaan..." style="font-size: 0.85rem;">
                        </div>
                        
                        <!-- Filter Tanggal -->
                        <div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-3 filter-pill">
                            <span class="text-muted fw-bold me-1" style="font-size: 0.85rem;">Periode:</span>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 shadow-none px-0 py-0 m-0 text-muted" id="startDateFilter" onchange="applyFilter()" style="font-size: 0.85rem; width: 105px;">
                            <span class="text-muted mx-1" style="font-size: 0.85rem;">-</span>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 shadow-none px-0 py-0 m-0 text-muted" id="endDateFilter" onchange="applyFilter()" style="font-size: 0.85rem; width: 105px;">
                        </div>
                        
                        <!-- Filter Jenis Pengujian -->
                        <div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-3 filter-pill">
                            <select class="form-select form-select-sm bg-transparent border-0 shadow-none text-muted ps-0 py-0 m-0" id="testTypeFilter" style="width: 150px; cursor: pointer; font-size: 0.85rem;">
                                <option value="">Semua Tipe</option>
                                <option value="PENGUJIAN BAHAN">PENGUJIAN BAHAN</option>
                                <option value="PENGUJIAN KONSTRUKSI">PENGUJIAN KONSTRUKSI</option>
                            </select>
                        </div>

                        <!-- Filter Kategori -->
                        <div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-3 filter-pill">
                            <select class="form-select form-select-sm bg-transparent border-0 shadow-none text-muted ps-0 py-0 m-0" id="testCategoryFilter" style="width: 160px; cursor: pointer; font-size: 0.85rem;">
                                <option value="">Semua Kategori</option>
                                <option value="Agregat">Agregat</option>
                                <option value="Tanah">Tanah</option>
                                <option value="Besi / Baja">Besi / Baja</option>
                                <option value="Mortar / Lainnya">Mortar / Lainnya</option>
                                <option value="Beton">Beton</option>
                                <option value="Aspal">Aspal</option>
                            </select>
                        </div>

                        <!-- Filter Status -->
                        <div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-3 filter-pill">
                            <select class="form-select form-select-sm bg-transparent border-0 shadow-none text-muted ps-0 py-0 m-0" id="statusSelect" style="width: 150px; cursor: pointer; font-size: 0.85rem;">
                                <option value="">Semua Status</option>
                                <option value="Menunggu Verifikasi">Menunggu Verifikasi</option>
                                <option value="Pengecekan Sampel">Pengecekan Sampel</option>
                                <option value="Belum Bayar">Belum Bayar</option>
                                <option value="Menunggu SKRD Upload">Menunggu SKRD</option>
                                <option value="Belum Lunas">Belum Lunas</option>
                                <option value="Lunas">Lunas</option>
                                <option value="Sedang Diuji">Sedang Diuji</option>
                                <option value="Selesai">Selesai</option>
                                <option value="Dibatalkan">Dibatalkan</option>
                            </select>
                        </div>
                        
                        <!-- Sort -->
                        <div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-3 filter-pill">
                            <select class="form-select form-select-sm bg-transparent border-0 shadow-none text-muted ps-0 py-0 m-0" id="sortSelect" style="width: 75px; cursor: pointer; font-size: 0.85rem;">
                                <option value="desc">Terbaru</option>
                                <option value="asc">Terlama</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Table Card -->
                <div class="card-custom p-0 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="bg-light">
                                <tr>
                                    <th>ID Pengajuan</th>
                                    <th>Perusahaan / Pemohon</th>
                                    <th>Jenis Pengujian</th>
                                    <th>Tanggal</th>
                                    <th>Status</th>
                                    <th class="text-center">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="submissionsTableBody">
                                <tr>
                                    <td colspan="6" class="text-center py-4">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                        <p class="text-muted mt-2">Memuat data...</p>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div class="card-footer bg-white border-0 py-3 px-4 d-flex justify-content-between align-items-center">
                        <small class="text-muted" id="paginationInfo"></small>
                        <nav aria-label="Page navigation">
                            <ul class="pagination mb-0" id="pagination">
                                <!-- Akan diisi JavaScript -->
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Bootstrap JS for dropdown -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS for submissions -->
    <script src="/js/admin/submissions.js?v=4"></script>
</body>
</html>