<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body>
    
    <div class="app-wrapper">
        <%- include('partials/sidebar', { page: 'settings' }) %>

        <main class="main-content">
            <%- include('partials/top-navbar', { pageTitle: 'Pengaturan Sistem' }) %>

            <div class="content-body">
                <!-- Alert Message -->
                <div id="alertMessage" class="alert alert-dismissible fade show position-fixed top-0 end-0 m-3" style="display: none; z-index: 10000;"></div>

                <div class="mb-4">
                    <h4 class="fw-bold text-dark m-0">Pengaturan Sistem</h4>
                    <p class="text-muted small m-0">Kelola profil administrator dan konfigurasi global aplikasi.</p>
                </div>

                <div class="row g-4">
            
            <!-- Sidebar Navigation -->
            <div class="col-md-3">
                <div class="card-custom p-0 overflow-hidden sticky-top" style="top: 20px; z-index: 1;">
                    <div class="list-group list-group-flush" id="settingsNav">
                        <a href="#profile" class="list-group-item list-group-item-action py-3 px-4 active border-0" onclick="switchSection('profile')">
                            <i class="fas fa-user-circle me-2"></i> Profil Admin
                        </a>
                        <a href="#security" class="list-group-item list-group-item-action py-3 px-4 border-0" onclick="switchSection('security')">
                            <i class="fas fa-lock me-2"></i> Keamanan
                        </a>
                        <a href="#system" class="list-group-item list-group-item-action py-3 px-4 border-0" onclick="switchSection('system')">
                            <i class="fas fa-sliders-h me-2"></i> Konfigurasi Aplikasi
                        </a>
                        <a href="#busy-mode" class="list-group-item list-group-item-action py-3 px-4 border-0" onclick="switchSection('busy-mode')">
                            <i class="fas fa-clock me-2"></i> Mode Sibuk
                        </a>
                        <a href="#backup" class="list-group-item list-group-item-action py-3 px-4 border-0" onclick="switchSection('backup')">
                            <i class="fas fa-database me-2"></i> Backup & Restore
                        </a>
                        <a href="#logs" class="list-group-item list-group-item-action py-3 px-4 border-0" onclick="switchSection('logs')">
                            <i class="fas fa-history me-2"></i> Log Aktivitas
                        </a>
                    </div>
                </div>
            </div>

            <!-- Settings Content -->
            <div class="col-md-9" id="settingsContent">

                <!-- Profile Section -->
                <div id="profile-section" class="settings-section">
                    <div class="card-custom mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                            <h6 class="fw-bold m-0 text-primary">
                                <i class="fas fa-user-circle me-2"></i>Informasi Pribadi Admin
                            </h6>
                            <span class="badge bg-light text-muted" id="lastProfileUpdate"></span>
                        </div>
                        <form id="profileForm" onsubmit="updateProfile(event)">
                            <div class="row mb-3">
                                <div class="col-md-4 text-center mb-3">
                                    <div class="image-upload-wrapper">
                                        <img id="profileImage" 
                                             src="" 
                                             class="rounded-circle mb-3 border border-3 border-white shadow-sm" 
                                             alt="Profile" 
                                             width="120" height="120" 
                                             style="object-fit: cover;">
                                        
                                        <div class="upload-overlay" onclick="document.getElementById('fileInput').click()">
                                            <i class="fas fa-camera"></i>
                                        </div>

                                        <input type="file" id="fileInput" class="d-none" accept="image/*" onchange="previewImage(event)">
                                    </div>
                                    <div class="small text-muted mt-1">Format: JPG/PNG, Max 2MB</div>
                                    <button type="button" class="btn btn-sm btn-outline-danger mt-2" onclick="removeProfileImage()">
                                        <i class="fas fa-trash me-1"></i>Hapus Foto
                                    </button>
                                </div>

                                <div class="col-md-8">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold text-muted">
                                                Nama Lengkap <span class="text-danger">*</span>
                                            </label>
                                            <input type="text" class="form-control" id="fullName" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold text-muted">
                                                Email Resmi <span class="text-danger">*</span>
                                            </label>
                                            <input type="email" class="form-control" id="officialEmail" required>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label small fw-bold text-muted">Nomor Telepon</label>
                                            <input type="text" class="form-control" id="phoneNumber">
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label small fw-bold text-muted">Jabatan</label>
                                            <input type="text" class="form-control bg-light" id="position" readonly>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="text-end mt-3">
                                <button type="submit" class="btn btn-primary px-4" id="saveProfileBtn">
                                    <span id="saveProfileText">Simpan Profil</span>
                                    <span id="saveProfileSpinner" style="display: none;">
                                        <span class="spinner-border spinner-border-sm me-2"></span>Menyimpan...
                                    </span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Security Section -->
                <div id="security-section" class="settings-section" style="display: none;">
                    <div class="card-custom mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                            <h6 class="fw-bold m-0 text-primary">
                                <i class="fas fa-lock me-2"></i>Ganti Password
                            </h6>
                            <span class="badge bg-light text-muted" id="lastPasswordChange"></span>
                        </div>
                        <form id="passwordForm" onsubmit="changePassword(event)">
                            <!-- Password Saat Ini -->
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Password Saat Ini <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <input type="password" class="form-control bg-white" id="currentPassword" 
                                        placeholder="Masukkan password lama..." required>
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('currentPassword')">
                                        <i class="far fa-eye"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Password Baru & Konfirmasi -->
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-muted">Password Baru <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <input type="password" class="form-control bg-white" id="newPassword" 
                                            placeholder="Minimal 8 karakter" oninput="checkPasswordStrength()" required>
                                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('newPassword')">
                                            <i class="far fa-eye"></i>
                                        </button>
                                    </div>
                                    <div class="password-strength mt-2" id="passwordStrength"></div>
                                    <small class="text-muted" id="passwordHint"></small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-muted">Konfirmasi Password Baru <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <input type="password" class="form-control bg-white" id="confirmPassword" 
                                            placeholder="Ulangi password baru" oninput="checkPasswordMatch()" required>
                                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confirmPassword')">
                                            <i class="far fa-eye"></i>
                                        </button>
                                    </div>
                                    <small class="text-muted" id="passwordMatchHint"></small>
                                </div>
                            </div>

                            <div class="text-end mt-3">
                                <button type="submit" class="btn btn-primary px-4" id="changePasswordBtn">
                                    <span id="changePasswordText">Update Password</span>
                                    <span id="changePasswordSpinner" style="display: none;">
                                        <span class="spinner-border spinner-border-sm me-2"></span>Memproses...
                                    </span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- System Configuration Section -->
                <div id="system-section" class="settings-section" style="display: none;">
                    <div class="card-custom">
                        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                            <h6 class="fw-bold m-0 text-primary">
                                <i class="fas fa-sliders-h me-2"></i>Konfigurasi Aplikasi
                            </h6>
                        </div>
                        <form id="systemForm" onsubmit="updateSystemConfig(event)">
                            <!-- SEMUA FIELD DIHAPUS KECUALI MAINTENANCE DAN UPLOAD -->
                            <div class="row align-items-center bg-light p-3 rounded-3 mx-0 mb-3">
                                <div class="col-md-9">
                                    <h6 class="fw-bold m-0">Mode Maintenance</h6>
                                    <small class="text-muted">Jika diaktifkan, user (pemohon) tidak akan bisa login atau mengajukan uji baru.</small>
                                </div>
                                <div class="col-md-3 text-end">
                                    <div class="form-check form-switch d-inline-block">
                                        <input class="form-check-input" type="checkbox" id="maintenanceMode">
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Batas Upload File</label>
                                <select class="form-select" id="maxUploadSize">
                                    <option value="2">2 MB</option>
                                    <option value="5">5 MB</option>
                                    <option value="10">10 MB</option>
                                    <option value="20">20 MB</option>
                                </select>
                            </div>

                            <div class="text-end mt-4">
                                <button type="submit" class="btn btn-primary px-4">Simpan Konfigurasi</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Mode Sibuk Section -->
                <div id="busy-mode-section" class="settings-section" style="display: none;">
                    <div class="card-custom">
                        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                            <h6 class="fw-bold m-0 text-primary">
                                <i class="fas fa-clock me-2"></i>Mode Sibuk
                            </h6>
                        </div>
                        
                        <p class="text-muted small mb-4">
                            Saat mode sibuk diaktifkan, estimasi waktu pengerjaan di halaman user akan otomatis ditambahkan 
                            sesuai dengan periode yang ditentukan. Berguna untuk kondisi seperti maintenance alat, 
                            libur nasional, atau cuti bersama.
                        </p>
                        
                        <!-- Toggle Switch -->
                        <div class="row align-items-center bg-light p-4 rounded-3 mx-0 mb-4">
                            <div class="col-md-8">
                                <h6 class="fw-bold mb-1">Aktifkan Mode Sibuk</h6>
                                <small class="text-muted">
                                    Jika diaktifkan, semua pengajuan akan mendapatkan tambahan waktu sesuai periode sibuk
                                </small>
                            </div>
                            <div class="col-md-4 text-end">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input" type="checkbox" id="busyModeToggle" style="width: 3rem; height: 1.5rem;">
                                </div>
                            </div>
                        </div>
                        
                        <!-- Periode Sibuk (ditampilkan jika toggle aktif) -->
                        <div id="busyPeriodContainer" style="display: none;">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-bold">Periode Sibuk</h6>
                                <button class="btn btn-sm btn-outline-primary" onclick="tambahPeriodeSibuk()">
                                    <i class="fas fa-plus me-1"></i>Tambah Periode
                                </button>
                            </div>
                            
                            <!-- Daftar Periode Sibuk -->
                            <div id="busyPeriodList">
                                <!-- Akan diisi dari database -->
                            </div>
                            
                            <!-- Form Tambah/Edit Periode (awalnya hidden) -->
                            <div id="busyPeriodForm" class="mt-4 p-3 bg-light rounded" style="display: none;">
                                <h6 class="fw-bold mb-3" id="periodFormTitle">Tambah Periode Sibuk</h6>
                                <form id="periodForm">
                                    <input type="hidden" id="periodId">
                                    
                                    <div class="mb-3">
                                        <label class="form-label">Keterangan</label>
                                        <input type="text" class="form-control" id="periodKeterangan" 
                                            placeholder="Contoh: Maintenance Alat, Libur Nasional, Cuti Bersama" required>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Tanggal Mulai</label>
                                            <input type="date" class="form-control" id="periodMulai" required>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Tanggal Selesai</label>
                                            <input type="date" class="form-control" id="periodSelesai" required>
                                        </div>
                                    </div>
                                    
                                    <div class="text-end">
                                        <button type="button" class="btn btn-light me-2" onclick="batalEditPeriode()">Batal</button>
                                        <button type="button" class="btn btn-primary" onclick="simpanPeriode()">Simpan</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                        
                        <div class="text-end mt-4">
                            <button class="btn btn-primary px-4" onclick="simpanModeSibuk(event)">
                                Simpan Perubahan
                            </button>                        
                        </div>
                    </div>
                </div>

                <!-- Backup Section -->
                <div id="backup-section" class="settings-section" style="display: none;">
                    <div class="card-custom">
                        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                            <h6 class="fw-bold m-0 text-primary">
                                <i class="fas fa-database me-2"></i>Backup & Restore
                            </h6>
                        </div>
                        
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="bg-light p-4 rounded text-center">
                                    <i class="fas fa-download fa-3x text-primary mb-3"></i>
                                    <h6 class="fw-bold">Backup Database</h6>
                                    <p class="small text-muted">Download backup database terbaru</p>
                                    <button class="btn btn-primary" onclick="createBackup()">
                                        <i class="fas fa-database me-2"></i>Buat Backup
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="bg-light p-4 rounded text-center">
                                    <i class="fas fa-upload fa-3x text-success mb-3"></i>
                                    <h6 class="fw-bold">Restore Database</h6>
                                    <p class="small text-muted">Upload file backup untuk restore</p>
                                    <button class="btn btn-success" onclick="document.getElementById('restoreFile').click()">
                                        <i class="fas fa-upload me-2"></i>Restore
                                    </button>
                                    <input type="file" id="restoreFile" class="d-none" accept=".sql,.gz" onchange="restoreBackup()">
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <h6 class="fw-bold mb-3">Backup History</h6>
                        <div id="backupHistory">
                            <!-- Akan diisi dari database -->
                        </div>
                    </div>
                </div>

                <!-- Activity Logs Section -->
                <div id="logs-section" class="settings-section" style="display: none;">
                    <div class="card-custom">
                        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                            <h6 class="fw-bold m-0 text-primary">
                                <i class="fas fa-history me-2"></i>Log Aktivitas
                            </h6>
                            <div>
                                <select class="form-select form-select-sm" id="logFilter" onchange="loadActivityLogs()">
                                    <option value="all">Semua Aktivitas</option>
                                    <option value="login">Login</option>
                                    <option value="update">Update</option>
                                    <option value="create">Create</option>
                                    <option value="delete">Delete</option>
                                    <option value="backup">Backup</option>
                                </select>
                            </div>
                        </div>
                        
                        <div id="activityLogs">
                            <!-- Akan diisi dari database -->
                        </div>

                        <div class="text-center mt-4">
                            <button class="btn btn-outline-primary btn-sm" onclick="loadMoreLogs()">Load More</button>
                        </div>
                    </div>
                </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="/js/admin/settings.js"></script>
</body>
</html>
