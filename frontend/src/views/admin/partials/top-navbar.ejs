<div class="top-navbar">
    <div class="navbar-left">
        <button class="mobile-sidebar-toggle" id="mobileSidebarToggle">
            <i class="fas fa-bars"></i>
        </button>
        <div class="page-heading">
            <h2 class="page-title"><%= locals.pageTitle || 'Admin Panel' %></h2>
            <p class="page-datetime" id="currentDateTime">Loading...</p>
        </div>
    </div>
    
    <div class="navbar-right">
        <!-- Notification -->
        <div class="notification-wrapper">
            <button class="notification-bell" id="notificationBtn" onclick="toggleNotificationPanel()">
                <i class="far fa-bell"></i>
                <% if (locals.notificationCount > 0) { %>
                    <span class="notification-badge"><%= notificationCount %></span>
                <% } %>
            </button>
            
            <div class="notification-panel" id="notificationPanel" style="display: none;">
                <div class="notification-panel-header">
                    <h4>Notifikasi</h4>
                    <button class="notification-action" onclick="markAllAsRead()">Tandai dibaca</button>
                </div>
                <div class="notification-panel-body" id="notificationList">
                    <div class="notification-empty">
                        <i class="far fa-bell-slash"></i>
                        <p>Tidak ada notifikasi baru</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- User Account -->
        <div class="account-dropdown ms-2">
            <div class="account-info">
                <div class="account-avatar">
                    <% 
                        let adminAvatarSrc = "https://ui-avatars.com/api/?name=Admin+User&background=047857&color=fff";
                        if (locals.user && locals.user.avatar) {
                            const finalBackendUrl = (typeof backendUrl !== 'undefined' && backendUrl) ? backendUrl : 'http://localhost:5000';
                            adminAvatarSrc = locals.user.avatar.startsWith('http') ? locals.user.avatar : (finalBackendUrl + locals.user.avatar);
                        } else if (locals.user && (locals.user.full_name || locals.user.name)) {
                            const adminName = locals.user.full_name || locals.user.name;
                            adminAvatarSrc = "https://ui-avatars.com/api/?name=" + encodeURIComponent(adminName) + "&background=047857&color=fff";
                        }
                    %>
                    <img src="<%= adminAvatarSrc %>" class="avatar-image" alt="Admin Avatar">
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Update DateTime
    function updateDateTime() {
        const dtElement = document.getElementById('currentDateTime');
        if (!dtElement) return;
        
        const now = new Date();
        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
        dtElement.textContent = now.toLocaleDateString('id-ID', options).replace('pukul', '|');
    }
    
    setInterval(updateDateTime, 60000);
    updateDateTime();
    
    // Toggle Notification
    function toggleNotificationPanel() {
        const panel = document.getElementById('notificationPanel');
        if (panel) {
            panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
        }
    }
    
    async function markAllAsRead() {
        try {
            let token = localStorage.getItem('token') || localStorage.getItem('admin_token');
            if (!token) {
                const tokenMatch = document.cookie.match(/token=([^;]+)/);
                if (tokenMatch) token = tokenMatch[1];
            }
            if (!token) return;
            
            await fetch(`<%= typeof backendUrl !== 'undefined' ? backendUrl : 'http://localhost:5000' %>/api/notifications/admin/mark-all-read`, {
                method: 'PUT',
                headers: { Authorization: `Bearer ${token}` }
            });

            const list = document.getElementById('notificationList');
            if (list) {
                list.innerHTML = `
                    <div class="notification-empty" style="padding: 20px; text-align: center; color: #94a3b8;">
                        <i class="far fa-bell-slash" style="font-size: 24px; margin-bottom: 8px;"></i>
                        <p style="margin: 0; font-size: 0.9rem;">Tidak ada notifikasi baru</p>
                    </div>
                `;
                
                const badge = document.querySelector('.notification-badge');
                if (badge) badge.remove();
            }
        } catch (e) {
            console.error("Error marking all as read:", e);
        }
    }
    
    // Close panel when click outside
    document.addEventListener('click', function(e) {
        const wrapper = document.querySelector('.notification-wrapper');
        const panel = document.getElementById('notificationPanel');
        
        if (wrapper && panel && !wrapper.contains(e.target) && panel.style.display === 'block') {
            panel.style.display = 'none';
        }
    });

    // Fetch avatar & notifications dynamically
    document.addEventListener('DOMContentLoaded', async () => {
        try {
            const API_BASE_URL = `<%= typeof backendUrl !== 'undefined' ? backendUrl : 'http://localhost:5000' %>/api`;
            // Get token from localStorage or cookie
            let token = localStorage.getItem('token') || localStorage.getItem('admin_token');
            if (!token) {
                const tokenMatch = document.cookie.match(/token=([^;]+)/);
                if (tokenMatch) token = tokenMatch[1];
            }
            if (!token) return;
            
            const headers = { Authorization: `Bearer ${token}` };

            // 1. Fetch Profile for Avatar
            fetch(`${API_BASE_URL}/settings/profile`, { headers })
                .then(res => res.json())
                .then(data => {
                    if (data.success && data.data) {
                        const avatarSrc = data.data.avatar 
                            ? (data.data.avatar.startsWith('http') ? data.data.avatar : `<%= typeof backendUrl !== 'undefined' ? backendUrl : 'http://localhost:5000' %>${data.data.avatar}`)
                            : `https://ui-avatars.com/api/?name=${encodeURIComponent(data.data.full_name || data.data.name || 'Admin+User')}&background=047857&color=fff`;
                        const avatars = document.querySelectorAll('.avatar-image');
                        avatars.forEach(img => img.src = avatarSrc);
                    }
                }).catch(err => console.error("Error fetching avatar:", err));

            function fetchAdminNotifications() {
                // 2. Fetch True Admin Notifications
                fetch(`${API_BASE_URL}/notifications/admin`, { headers })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success && data.data) {
                            const notifications = data.data;
                            const unreadNotifs = notifications.filter(n => !n.is_read);
                            const list = document.getElementById('notificationList');
                            
                            if (notifications.length > 0) {
                                list.innerHTML = notifications.slice(0, 10).map(act => `
                                    <a href="${act.href || '#'}" class="notification-item ${!act.is_read ? 'unread' : ''}" style="display: block; padding: 12px; border-bottom: 1px solid #f1f5f9; text-decoration: none; color: inherit; ${!act.is_read ? 'background-color: #f8fafc;' : ''}">
                                        <div style="font-weight: 600; font-size: 0.9rem; color: #1e293b;">${act.title}</div>
                                        <div style="font-size: 0.85rem; color: #475569; margin: 4px 0;">${act.message}</div>
                                    </a>
                                `).join('');
                                
                                // Update badge
                                if (unreadNotifs.length > 0) {
                                    let badge = document.querySelector('.notification-badge');
                                    if (!badge) {
                                        badge = document.createElement('span');
                                        badge.className = 'notification-badge';
                                        document.getElementById('notificationBtn').appendChild(badge);
                                    }
                                    badge.textContent = unreadNotifs.length > 9 ? '9+' : unreadNotifs.length;
                                } else {
                                    const badge = document.querySelector('.notification-badge');
                                    if (badge) badge.remove();
                                }
                            } else {
                                list.innerHTML = `
                                    <div class="notification-empty" style="padding: 20px; text-align: center; color: #94a3b8;">
                                        <i class="far fa-bell-slash" style="font-size: 24px; margin-bottom: 8px;"></i>
                                        <p style="margin: 0; font-size: 0.9rem;">Tidak ada notifikasi baru</p>
                                    </div>
                                `;
                                const badge = document.querySelector('.notification-badge');
                                if (badge) badge.remove();
                            }
                        }
                    }).catch(err => console.error("Error fetching notifications:", err));
            }
            
            fetchAdminNotifications();
            
            // Listen for Realtime Socket.IO Events
            window.addEventListener('socket_notification', function(e) {
                console.log('Admin Realtime notification received:', e.detail);
                fetchAdminNotifications();
            });

        } catch (error) {
            console.error("Error initializing top navbar:", error);
        }

        // Mobile Sidebar Toggle
        const toggleBtn = document.getElementById('mobileSidebarToggle');
        const sidebar = document.querySelector('.sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        
        if (toggleBtn && sidebar) {
            toggleBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                sidebar.classList.toggle('active');
                if (overlay) overlay.classList.toggle('active');
            });
        }

        if (overlay) {
            overlay.addEventListener('click', () => {
                sidebar.classList.remove('active');
                overlay.classList.remove('active');
            });
        }
        
        document.addEventListener('click', (e) => {
            if (window.innerWidth <= 768) {
                if (sidebar && !sidebar.contains(e.target) && toggleBtn && !toggleBtn.contains(e.target)) {
                    sidebar.classList.remove('active');
                    if (overlay) overlay.classList.remove('active');
                }
            }
        });
    });
</script>
