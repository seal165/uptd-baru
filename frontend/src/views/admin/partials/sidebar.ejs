        <div class="logo-section">
            <h1 class="logo-title">UPTD PBKBIK</h1>
            <p class="logo-subtitle">Provinsi Banten</p>
        </div>
        
        <nav class="main-menu">
            <ul>
                <li class="menu-item <%= page === 'dashboard' ? 'active' : '' %>">
                    <a href="/admin/dashboard" class="menu-link">
                        <i class="fas fa-th-large menu-icon"></i>
                        <span class="menu-text">Dashboard</span>
                    </a>
                </li>
                <li class="menu-item <%= page === 'submissions' ? 'active' : '' %>">
                    <a href="/admin/submissions" class="menu-link">
                        <i class="fas fa-folder-open menu-icon"></i>
                        <span class="menu-text">Submissions</span>
                    </a>
                </li>
                <li class="menu-item <%= page === 'skrd' ? 'active' : '' %>">
                    <a href="/admin/skrd" class="menu-link">
                        <i class="fas fa-money-bill-wave menu-icon"></i>
                        <span class="menu-text">Invoice / Payment</span>
                    </a>
                </li>
                <li class="menu-item <%= page === 'kuisioner' ? 'active' : '' %>">
                    <a href="/admin/kuisioner" class="menu-link">
                        <i class="fas fa-poll menu-icon"></i>
                        <span class="menu-text">Kuisioner</span>
                    </a>
                </li>
                <li class="menu-item <%= page === 'users' ? 'active' : '' %>">
                    <a href="/admin/users" class="menu-link">
                        <i class="fas fa-users menu-icon"></i>
                        <span class="menu-text">User Management</span>
                    </a>
                </li>
                <li class="menu-item <%= page === 'settings' ? 'active' : '' %>">
                    <a href="/admin/settings" class="menu-link">
                        <i class="fas fa-cog menu-icon"></i>
                        <span class="menu-text">Settings</span>
                    </a>
                </li>
            </ul>
        </nav>
        
        <div class="sidebar-footer">
            <button class="logout-btn" onclick="handleLogout()">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </button>
        </div>
    </div>
</aside>

<script>
    function handleLogout() {
        if (confirm('Apakah Anda yakin ingin logout?')) {
            localStorage.removeItem('admin_token');
            localStorage.removeItem('user_data');
            localStorage.removeItem('remember_me');
            window.location.href = '/admin/login';
        }
    }
</script>