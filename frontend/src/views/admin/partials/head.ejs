<meta charset="UTF-8">
<title>Admin Panel - UPTD Lab</title>
<link rel="icon" type="image/png" href="/img/logo.png">
<!-- Google Fonts (from user) -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<!-- Base Layout & Reset Styles -->
<link rel="stylesheet" href="/css/user-style.css?v=12">
<!-- Admin Styles (overrides user-style where needed) -->
<link rel="stylesheet" href="/css/admin-style.css?v=5">
<!-- Anti-FOUC: Pastikan sidebar admin tidak flash hijau saat CSS eksternal loading -->
<style>
  .sidebar .menu-item.active,
  .main-menu .menu-item.active { background: #f1f5f9 !important; }
  .sidebar .menu-item.active .menu-link,
  .main-menu .menu-item.active .menu-link { color: #047857 !important; font-weight: 600 !important; }
  /* Non-active item: tidak ada background, cegah glitch dari user-style */
  .sidebar .menu-item:not(.active),
  .main-menu .menu-item:not(.active) { background: transparent !important; }
</style>
<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<!-- Settings & Config dari server via data attribute untuk mencegah linter error -->
<div id="serverData" 
     data-settings='<%- JSON.stringify(locals.settings || {}).replace(/&apos;/g, "\\&apos;") %>' 
     data-config='<%- JSON.stringify(locals.appConfig || {}).replace(/&apos;/g, "\\&apos;") %>' 
     style="display:none;"></div>
<script>
    (function() {
        try {
            var el = document.getElementById('serverData');
            if (el) {
                window.settings = JSON.parse(el.getAttribute('data-settings') || '{}');
                window.__APP_CONFIG__ = JSON.parse(el.getAttribute('data-config') || '{}');
            } else {
                window.settings = {};
                window.__APP_CONFIG__ = {};
            }
        } catch (e) {
            console.warn('Config parse error:', e);
            window.settings = {};
            window.__APP_CONFIG__ = {};
        }
    })();
</script>