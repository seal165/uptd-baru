<script>
    window.__APP_CONFIG__ = <%- JSON.stringify(locals.appConfig || {}).replace(/</g, '\\u003c') %>;
</script>

<!-- 
    🔥 Pass settings from server to JavaScript using data attribute.
    This avoids linter errors because EJS is not inside <script> tag.
-->
<script>
    (function() {
        try {
            var settingsEl = document.getElementById('app-settings');
            if (settingsEl) {
                window.settings = JSON.parse(settingsEl.dataset.settings || '{}');
            } else {
                window.settings = {};
            }
        } catch (e) {
            console.warn('Failed to parse settings:', e);
            window.settings = {};
        }
    })();
</script>