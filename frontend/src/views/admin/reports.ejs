<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body>

    <div class="app-wrapper">
        <%- include('partials/sidebar', { page: 'reports' }) %>

        <main class="main-content">
            <%- include('partials/top-navbar', { pageTitle: 'Laporan & Statistik' }) %>

            <div class="content-body">
                <!-- Alert Message -->
                <div id="alertMessage" class="alert alert-dismissible fade show" style="display: none;"></div>

                <!-- Header -->
                <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-bold text-dark m-0">Laporan & Statistik</h4>
                        <p class="text-muted small m-0">Analisis kinerja laboratorium dan rekapitulasi pendapatan.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-primary btn-sm bg-white btn-export" onclick="exportToPDF()">
                            <i class="fas fa-print me-2"></i>Cetak PDF
                        </button>
                        <button class="btn btn-success btn-sm text-white btn-export" onclick="exportToExcel()">
                            <i class="fas fa-file-excel me-2"></i>Export Excel
                        </button>
                    </div>
                </div>

                <!-- Filter Section -->
                <div class="card-custom mb-4">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3 text-uppercase small text-muted">
                            <i class="fas fa-filter me-2"></i>Filter Data
                        </h6>
                        
                        <!-- Quick Date Filters -->
                        <div class="d-flex gap-2 mb-3 flex-wrap">
                            <span class="badge bg-light text-dark filter-badge" onclick="setQuickFilter('today')">Hari Ini</span>
                            <span class="badge bg-light text-dark filter-badge" onclick="setQuickFilter('yesterday')">Kemarin</span>
                            <span class="badge bg-light text-dark filter-badge" onclick="setQuickFilter('week')">7 Hari Terakhir</span>
                            <span class="badge bg-light text-dark filter-badge" onclick="setQuickFilter('month')">30 Hari Terakhir</span>
                            <span class="badge bg-light text-dark filter-badge" onclick="setQuickFilter('quarter')">3 Bulan Terakhir</span>
                            <span class="badge bg-light text-dark filter-badge" onclick="setQuickFilter('year')">Tahun Ini</span>
                        </div>

                        <!-- Filter Form (tanpa tombol) -->
                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-muted">Periode Awal</label>
                                <input type="date" class="form-control bg-light border-0 shadow-none" 
                                    id="startDate" onchange="applyFilter()" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-muted">Periode Akhir</label>
                                <input type="date" class="form-control bg-light border-0 shadow-none" 
                                    id="endDate" onchange="applyFilter()" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-muted">Kategori Uji</label>
                                <select class="form-select bg-light border-0 shadow-none" id="category" onchange="applyFilter()">
                                    <option value="">Semua Kategori</option>
                                    <option value="Beton">Uji Beton</option>
                                    <option value="Tanah">Uji Tanah</option>
                                    <option value="Aspal">Uji Aspal</option>
                                    <option value="Baja">Uji Baja</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Summary Stats - TAMPILAN BARU (lebih sederhana) -->
                <div class="stats-grid" id="summaryStats">
                    <!-- Akan diisi JavaScript (fungsi updateSummaryStats sudah ada) -->
                </div>

                <!-- Charts Row - TAMPILAN BARU -->
                <div class="chart-row">
                    <!-- Bar Chart - Tren Pendapatan -->
                    <div class="chart-card">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="chart-title">Tren Pendapatan</h6>
                            <select class="form-select form-select-sm w-auto" id="chartType" onchange="updateChartType()">
                                <option value="bar">Bar</option>
                                <option value="line">Line</option>
                                <option value="area">Area</option>
                            </select>
                        </div>
                        <div style="height: 250px;">
                            <canvas id="revenueChart"></canvas>
                        </div>
                        <div class="row g-3 mt-3 text-center" id="revenueStats">
                            <!-- Akan diisi JavaScript -->
                        </div>
                    </div>

                    <!-- Pie Chart - Proporsi Layanan -->
                    <div class="chart-card">
                        <h6 class="chart-title">Proporsi Layanan</h6>
                        <div style="height: 200px;">
                            <canvas id="serviceChart"></canvas>
                        </div>
                        <div class="mt-3" id="serviceLegend">
                            <!-- Akan diisi JavaScript -->
                        </div>
                    </div>
                </div>

                <!-- Additional Stats Row - TAMPILAN BARU -->
                <div class="stats-row">
                    <!-- Status Distribution -->
                    <div class="chart-card">
                        <h6 class="chart-title">Status Pengajuan</h6>
                        <div style="height: 200px;">
                            <canvas id="statusChart"></canvas>
                        </div>
                    </div>

                    <!-- Top Clients -->
                    <div class="chart-card">
                        <h6 class="chart-title">Top 5 Perusahaan</h6>
                        <div class="data-list" id="topClients">
                            <!-- Akan diisi JavaScript -->
                        </div>
                    </div>

                    <!-- Monthly Growth -->
                    <div class="chart-card">
                        <h6 class="chart-title">Pertumbuhan Bulanan</h6>
                        <div class="data-list" id="monthlyGrowth">
                            <!-- Akan diisi JavaScript -->
                        </div>
                    </div>
                </div>

                <!-- Transactions Table (HAPUS TOMBOL DOWNLOAD) -->
                <div class="chart-card mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="chart-title">Rincian Transaksi</h6>
                        <span class="text-muted small" id="transactionCount"></span>
                    </div>
                    <div class="table-responsive">
                        <table class="table-clean">
                            <thead>
                                <tr>
                                    <th>Tanggal</th>
                                    <th>No. Referensi</th>
                                    <th>Perusahaan</th>
                                    <th>Uraian</th>
                                    <th>Kategori</th>
                                    <th class="text-end">Nilai</th>
                                </tr>
                            </thead>
                            <tbody id="transactionsTableBody">
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">
                                        <div class="spinner-border spinner-border-sm me-2"></div>
                                        Memuat data...
                                    </td>
                                </tr>
                            </tbody>
                            <tfoot id="tableFooter">
                                <!-- Akan diisi JavaScript -->
                            </tfoot>
                        </table>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <small class="text-muted" id="paginationInfo"></small>
                        <nav>
                            <ul class="pagination pagination-sm mb-0" id="pagination">
                                <!-- Akan diisi JavaScript -->
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Chart.js - LOAD DULU -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SheetJS untuk export Excel -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

    <!-- jsPDF untuk export PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>

    <script>
        // ==================== KONFIGURASI ====================
        const API_BASE_URL = (window.__APP_CONFIG__ && window.__APP_CONFIG__.apiUrl) || '/api';
        const ITEMS_PER_PAGE = 10;
        const LOAD_TIMEOUT = 10000; // 10 detik max loading
        
        // State
        let currentPage = 1;
        let startDate = '';
        let endDate = '';
        let category = '';
        let totalData = 0;
        let reportData = null;
        let loadingTimeout;
        
        // Chart instances
        let revenueChart = null;
        let serviceChart = null;
        let statusChart = null;

        // Cache sederhana
        const cache = {
            reports: { data: null, timestamp: null, params: '' }
        };
        const CACHE_DURATION = 60000; // 60 detik

        // ==================== CEK TOKEN ====================
        function getToken() {
            return localStorage.getItem('admin_token');
        }

        if (!getToken()) {
            window.location.href = '/admin/login';
        }

        // ==================== FUNGSI FETCH DENGAN TIMEOUT ====================
        async function fetchWithTimeout(url, options = {}, timeout = LOAD_TIMEOUT) {
            const controller = new AbortController();
            const id = setTimeout(() => controller.abort(), timeout);
            
            try {
                const response = await fetch(url, {
                    ...options,
                    signal: controller.signal
                });
                clearTimeout(id);
                return response;
            } catch (error) {
                clearTimeout(id);
                if (error.name === 'AbortError') {
                    throw new Error('Request timeout - server terlalu lama merespon');
                }
                throw error;
            }
        }

        // ==================== FUNGSI CACHE ====================
        function getCachedData() {
            const paramsStr = `${currentPage}_${startDate}_${endDate}_${category}`;
            if (cache.reports.data && 
                cache.reports.params === paramsStr &&
                (Date.now() - cache.reports.timestamp < CACHE_DURATION)) {
                console.log('Ã°Å¸â€œÂ¦ Using cached reports');
                return cache.reports.data;
            }
            return null;
        }

        function setCachedData(data) {
            cache.reports.data = data;
            cache.reports.params = `${currentPage}_${startDate}_${endDate}_${category}`;
            cache.reports.timestamp = Date.now();
        }

        // ==================== INITIALIZE DATES ====================
        function initializeDates() {
            const today = new Date();
            const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);
            
            const startInput = document.getElementById('startDate');
            const endInput = document.getElementById('endDate');
            
            if (startInput) startInput.value = formatDateForInput(firstDay);
            if (endInput) endInput.value = formatDateForInput(today);
            
            startDate = firstDay.toISOString().split('T')[0];
            endDate = today.toISOString().split('T')[0];
        }

        // ==================== LOAD DATA ====================
        async function loadReportData(showLoadingIndicator = true) {
            // Cek cache dulu
            const cachedData = getCachedData();
            if (cachedData) {
                console.log('Ã°Å¸â€œÂ¦ Using cached data');
                reportData = cachedData;
                updateAllCharts(cachedData);
                showLoading(false);
                return;
            }
            
            if (showLoadingIndicator) showLoading(true);
            
            // Set timeout 5 detik
            loadingTimeout = setTimeout(() => {
                console.log('Ã¢Å¡Â Ã¯Â¸Â Loading timeout');
                showLoading(false);
                showAlert('Gagal memuat data: Server terlalu lama merespon', 'danger');
            }, 5000);
            
            try {
                const params = new URLSearchParams({
                    start_date: startDate,
                    end_date: endDate,
                    page: currentPage,
                    limit: ITEMS_PER_PAGE
                });

                if (category) params.append('category', category);

                console.log('Ã°Å¸â€œÂ¡ Fetching reports data...');
                console.log('URL:', `${API_BASE_URL}/reports?${params}`);

                const response = await fetch(`${API_BASE_URL}/reports?${params}`, {
                    headers: {
                        'Authorization': `Bearer ${getToken()}`,
                        'Content-Type': 'application/json'
                    }
                });

                clearTimeout(loadingTimeout);

                if (response.status === 401) {
                    localStorage.removeItem('admin_token');
                    window.location.href = '/admin/login';
                    return;
                }

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('Error response:', errorText);
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }

                const result = await response.json();
                console.log('Ã°Å¸â€œÂ¦ Response:', result);

                if (result.success) {
                    reportData = result.data;
                    setCachedData(result.data);
                    updateAllCharts(result.data);
                    showLoading(false);
                } else {
                    showAlert(result.message || 'Gagal memuat data', 'danger');
                    showLoading(false);
                }
            } catch (error) {
                clearTimeout(loadingTimeout);
                console.error('Ã¢ÂÅ’ Error:', error);
                
                if (error.message.includes('Failed to fetch')) {
                    showAlert('Tidak dapat terhubung ke server. Pastikan backend running di port 5000', 'danger');
                } else {
                    showAlert('Gagal terhubung ke server: ' + error.message, 'danger');
                }
                showLoading(false);
            }
        }

        // ==================== HAPUS FUNGSI DUMMY ====================
        // Fungsi showDummyData() dan showToast() dihapus

        // ==================== UPDATE ALL CHARTS ====================
        function updateAllCharts(data) {
            // Reset chart instances
            if (revenueChart) {
                revenueChart.destroy();
                revenueChart = null;
            }
            if (serviceChart) {
                serviceChart.destroy();
                serviceChart = null;
            }
            if (statusChart) {
                statusChart.destroy();
                statusChart = null;
            }
            
            // Update semua komponen
            if (data.summary) updateSummaryStats(data.summary);
            if (data.revenue_trend) updateRevenueChart(data.revenue_trend);
            if (data.service_distribution) updateServiceChart(data.service_distribution);
            if (data.status_distribution) updateStatusChart(data.status_distribution);
            if (data.top_clients) updateTopClients(data.top_clients);
            if (data.monthly_growth) updateMonthlyGrowth(data.monthly_growth);
            if (data.transactions) updateTransactionsTable(data.transactions);
            updatePagination();
            updatePeriodLabel();
        }

        // ==================== UPDATE SUMMARY STATS ====================
        function updateSummaryStats(summary) {
            const statsEl = document.getElementById('summaryStats');
            if (!statsEl) return;
            
            if (!summary) {
                statsEl.innerHTML = '<div class="stat-box">Tidak ada data</div>';
                return;
            }

            console.log('Ã°Å¸â€œÅ  Summary Stats:', summary); // Debug: lihat data summary

            const statsHtml = `
                <div class="stat-box">
                    <div class="stat-label">Total Pendapatan</div>
                    <div class="stat-value">${formatRupiah(summary.total_revenue || 0)}</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Total Transaksi</div>
                    <div class="stat-value">${summary.total_transactions || 0}</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Pengujian Selesai</div>
                    <div class="stat-value">${summary.completed_tests || 0}</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Perusahaan Aktif</div>
                    <div class="stat-value">${summary.active_clients || 0}</div>
                </div>
            `;
            
            statsEl.innerHTML = statsHtml;
        }

        // ==================== UPDATE REVENUE CHART ====================
        function updateRevenueChart(data) {
            const canvas = document.getElementById('revenueChart');
            if (!canvas) return;
            
            // Hancurkan chart lama jika ada
            if (revenueChart) {
                revenueChart.destroy();
                revenueChart = null;
            }

            if (!data || !data.labels || data.labels.length === 0) {
                canvas.style.display = 'none';
                return;
            }
            
            canvas.style.display = 'block';

            // Konversi nilai ke number
            const values = data.values.map(v => parseFloat(v) || 0);
            const max = parseFloat(data.max) || 0;
            const min = parseFloat(data.min) || 0;
            const avg = data.avg ? parseFloat(data.avg) : (values.length > 0 ? values.reduce((a, b) => a + b, 0) / values.length : 0);

            const chartType = document.getElementById('chartType')?.value || 'bar';
            
            try {
                revenueChart = new Chart(canvas.getContext('2d'), {
                    type: chartType === 'area' ? 'line' : chartType,
                    data: {
                        labels: data.labels || [],
                        datasets: [{
                            label: 'Pendapatan (Rp)',
                            data: values,
                            backgroundColor: chartType === 'bar' ? '#4361ee' : 'rgba(67, 97, 238, 0.2)',
                            borderColor: '#4361ee',
                            borderWidth: 2,
                            fill: chartType === 'area',
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return 'Rp ' + context.raw.toLocaleString('id-ID');
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function(value) {
                                        return 'Rp ' + (value / 1000000).toFixed(1) + 'jt';
                                    }
                                }
                            }
                        }
                    }
                });
            } catch (error) {
                console.error('Error creating revenue chart:', error);
            }

            const revenueStats = document.getElementById('revenueStats');
            if (revenueStats) {
                revenueStats.innerHTML = `
                    <div class="col-4">
                        <small class="text-muted d-block">Tertinggi</small>
                        <span class="fw-bold">${formatRupiah(max)}</span>
                    </div>
                    <div class="col-4">
                        <small class="text-muted d-block">Terendah</small>
                        <span class="fw-bold">${formatRupiah(min)}</span>
                    </div>
                    <div class="col-4">
                        <small class="text-muted d-block">Rata-rata</small>
                        <span class="fw-bold">${formatRupiah(Math.round(avg))}</span>
                    </div>
                `;
            }
        }

        // ==================== UPDATE SERVICE CHART ====================
        function updateServiceChart(data) {
            const canvas = document.getElementById('serviceChart');
            if (!canvas) return;
            
            // Hancurkan chart lama jika ada
            if (serviceChart) {
                serviceChart.destroy();
                serviceChart = null;
            }

            if (!data || !data.labels || data.labels.length === 0) {
                canvas.style.display = 'none';
                return;
            }
            
            canvas.style.display = 'block';

            const labels = data.labels || [];
            const values = data.values.map(v => parseFloat(v) || 0);
            
            // Warna berdasarkan kategori yang dipilih
            let backgroundColor = [];
            const selectedCategory = document.getElementById('category').value;
            
            if (selectedCategory) {
                // Jika ada kategori dipilih, kategori itu dapat warna khusus, sisanya abu-abu
                backgroundColor = labels.map(label => {
                    return label === selectedCategory ? '#4361ee' : '#e9ecef';
                });
            } else {
                // Jika tidak ada kategori dipilih, semua warna normal
                const colors = ['#4361ee', '#06d6a0', '#ffb703', '#ef476f', '#8338ec', '#3a86ff'];
                backgroundColor = colors.slice(0, labels.length);
            }
            
            try {
                serviceChart = new Chart(canvas.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: values,
                            backgroundColor: backgroundColor,
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const value = context.raw;
                                        const total = values.reduce((a, b) => a + b, 0);
                                        const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                        return `${context.label}: ${percentage}% (${formatRupiah(value)})`;
                                    }
                                }
                            }
                        },
                        cutout: '65%'
                    }
                });
            } catch (error) {
                console.error('Error creating service chart:', error);
            }

            // Update legend
            const total = values.reduce((a, b) => a + b, 0);
            const legendHtml = labels.map((label, index) => {
                const color = backgroundColor[index];
                const percentage = total > 0 ? ((values[index] / total) * 100).toFixed(1) : 0;
                
                return `
                    <div class="d-flex justify-content-between align-items-center small mb-2">
                        <span>
                            <i class="fas fa-circle me-2" style="color: ${color}"></i>
                            ${label}
                        </span>
                        <span class="fw-bold">${percentage}%</span>
                    </div>
                `;
            }).join('');

            const serviceLegend = document.getElementById('serviceLegend');
            if (serviceLegend) serviceLegend.innerHTML = legendHtml;
            
            const serviceCount = document.getElementById('serviceCount');
            if (serviceCount) serviceCount.textContent = `${labels.length} Kategori`;
        }

        // ==================== UPDATE STATUS CHART ====================
        function updateStatusChart(data) {
            const canvas = document.getElementById('statusChart');
            if (!canvas) return;
            
            // Hancurkan chart lama jika ada
            if (statusChart) {
                statusChart.destroy();
                statusChart = null;
            }

            if (!data || !data.labels || data.labels.length === 0) {
                canvas.style.display = 'none';
                return;
            }
            
            canvas.style.display = 'block';

            try {
                statusChart = new Chart(canvas.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: data.labels || [],
                        datasets: [{
                            data: data.values || [],
                            backgroundColor: ['#06d6a0', '#ffb703', '#4361ee', '#ef476f', '#6c757d'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'bottom' }
                        }
                    }
                });
            } catch (error) {
                console.error('Error creating status chart:', error);
            }
        }

        // ==================== UPDATE TOP CLIENTS ====================
        function updateTopClients(clients) {
            const topClientsEl = document.getElementById('topClients');
            if (!topClientsEl) return;
            
            if (!clients || clients.length === 0) {
                topClientsEl.innerHTML = '<p class="text-muted text-center py-3">Belum ada data</p>';
                return;
            }

            let html = '';
            clients.forEach((client, index) => {
                const total = parseFloat(client.total) || 0;
                html += `
                    <div class="data-item">
                        <div>
                            <span class="badge bg-primary me-2">${index + 1}</span>
                            <span class="item-name">${client.name || '-'}</span>
                            <small class="text-muted d-block">${client.transactions || 0} transaksi</small>
                        </div>
                        <span class="item-value">${formatRupiah(total)}</span>
                    </div>
                `;
            });
            
            topClientsEl.innerHTML = html;
        }

        // ==================== UPDATE MONTHLY GROWTH ====================
        function updateMonthlyGrowth(growth) {
            const monthlyGrowthEl = document.getElementById('monthlyGrowth');
            if (!monthlyGrowthEl) return;
            
            if (!growth || growth.length === 0) {
                monthlyGrowthEl.innerHTML = '<p class="text-muted text-center py-3">Belum ada data</p>';
                return;
            }

            let html = '';
            growth.forEach(item => {
                const revenue = parseFloat(item.revenue) || 0;
                const trendClass = item.growth >= 0 ? 'growth-positive' : 'growth-negative';
                const icon = item.growth >= 0 ? 'arrow-up' : 'arrow-down';
                
                html += `
                    <div class="data-item">
                        <span class="item-name">${item.month || '-'}</span>
                        <span class="item-value">${formatRupiah(revenue)}</span>
                        <span class="${trendClass}">
                            <i class="fas fa-${icon} me-1"></i>
                            ${Math.abs(item.growth || 0)}%
                        </span>
                    </div>
                `;
            });
            
            monthlyGrowthEl.innerHTML = html;
        }

        // ==================== UPDATE TRANSACTIONS TABLE ====================
        function updateTransactionsTable(transactions) {
            const tbody = document.getElementById('transactionsTableBody');
            const tableFooter = document.getElementById('tableFooter');
            
            if (!tbody) return;
            
            if (!transactions || transactions.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <p class="text-muted">Tidak ada transaksi</p>
                        </td>
                    </tr>
                `;
                if (tableFooter) tableFooter.innerHTML = '';
                return;
            }

            let totalAmount = 0;
            const rowsHtml = transactions.map(t => {
                const amount = parseFloat(t.amount) || 0;
                totalAmount += amount;
                
                return `
                    <tr>
                        <td>${formatDate(t.date)}</td>
                        <td><span class="badge bg-light text-dark">${t.reference || '-'}</span></td>
                        <td>${t.company || '-'}</td>
                        <td>${t.description || '-'}</td>
                        <td>${t.category || '-'}</td>
                        <td class="text-end fw-bold">${formatRupiah(amount)}</td>
                    </tr>
                `;
            }).join('');

            tbody.innerHTML = rowsHtml;

            // Update footer with total
            if (tableFooter) {
                tableFooter.innerHTML = `
                    <tr>
                        <td colspan="5" class="text-end fw-bold">Total</td>
                        <td class="text-end fw-bold text-primary">${formatRupiah(totalAmount)}</td>
                    </tr>
                `;
            }
        }

        // ==================== FILTER HANDLERS ====================
        function applyFilter() {
            const startInput = document.getElementById('startDate');
            const endInput = document.getElementById('endDate');
            const categorySelect = document.getElementById('category');
            
            if (startInput) startDate = startInput.value;
            if (endInput) endDate = endInput.value;
            if (categorySelect) category = categorySelect.value;
            
            console.log('Ã°Å¸Å½Â¯ Filter berubah:', { startDate, endDate, category });
            
            // Reset ke halaman pertama
            currentPage = 1;
            
            // Reset chart instances
            if (revenueChart) {
                revenueChart.destroy();
                revenueChart = null;
            }
            if (serviceChart) {
                serviceChart.destroy();
                serviceChart = null;
            }
            if (statusChart) {
                statusChart.destroy();
                statusChart = null;
            }
            
            // Muat ulang semua data
            loadReportData(true);
        }

        function setQuickFilter(period) {
            const today = new Date();
            let start = new Date();
            let end = new Date(today);
            
            switch(period) {
                case 'today':
                    start = today;
                    break;
                case 'yesterday':
                    start = new Date(today);
                    start.setDate(start.getDate() - 1);
                    end = new Date(start);
                    break;
                case 'week':
                    start.setDate(today.getDate() - 7);
                    break;
                case 'month':
                    start.setDate(today.getDate() - 30);
                    break;
                case 'quarter':
                    start.setMonth(today.getMonth() - 3);
                    break;
                case 'year':
                    start.setMonth(today.getMonth() - 12);
                    break;
            }
            
            const startInput = document.getElementById('startDate');
            const endInput = document.getElementById('endDate');
            
            if (startInput) startInput.value = formatDateForInput(start);
            if (endInput) endInput.value = formatDateForInput(end);
            
            startDate = start.toISOString().split('T')[0];
            endDate = end.toISOString().split('T')[0];
            
            loadReportData(true);
        }

        function updateChartType() {
            if (reportData && reportData.revenue_trend) {
                updateRevenueChart(reportData.revenue_trend);
            }
        }

        function updatePeriodLabel() {
            const trendPeriod = document.getElementById('trendPeriod');
            const lastUpdated = document.getElementById('lastUpdated');
            
            if (trendPeriod) {
                trendPeriod.textContent = `(${formatDate(startDate)} - ${formatDate(endDate)})`;
            }
            if (lastUpdated) {
                lastUpdated.textContent = `Updated: ${formatDateTime(new Date().toISOString())}`;
            }
        }

        // ==================== PAGINATION ====================
        function updatePagination() {
            const totalPages = Math.ceil(totalData / ITEMS_PER_PAGE);
            const pagination = document.getElementById('pagination');
            const paginationInfo = document.getElementById('paginationInfo');
            
            if (!pagination) return;
            
            if (totalPages <= 1) {
                pagination.innerHTML = '';
                if (paginationInfo) {
                    paginationInfo.innerHTML = `Menampilkan ${totalData} data`;
                }
                return;
            }

            let paginationHtml = '';
            
            paginationHtml += `
                <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link" href="#" onclick="changePage(${currentPage - 1})">Prev</a>
                </li>
            `;

            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
                    paginationHtml += `
                        <li class="page-item ${currentPage === i ? 'active' : ''}">
                            <a class="page-link" href="#" onclick="changePage(${i})">${i}</a>
                        </li>
                    `;
                } else if (i === currentPage - 3 || i === currentPage + 3) {
                    paginationHtml += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
            }

            paginationHtml += `
                <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                    <a class="page-link" href="#" onclick="changePage(${currentPage + 1})">Next</a>
                </li>
            `;

            pagination.innerHTML = paginationHtml;
            
            if (paginationInfo) {
                const start = ((currentPage - 1) * ITEMS_PER_PAGE) + 1;
                const end = Math.min(currentPage * ITEMS_PER_PAGE, totalData);
                paginationInfo.innerHTML = `Menampilkan ${start}-${end} dari ${totalData} data`;
            }
        }

        function changePage(page) {
            currentPage = page;
            loadReportData(true);
        }

        // ==================== EXPORT FUNCTIONS ====================
        function exportToExcel() {
            if (!reportData) {
                showAlert('Tidak ada data untuk diexport', 'warning');
                return;
            }
            
            if (typeof XLSX === 'undefined') {
                showAlert('Library XLSX tidak tersedia', 'danger');
                return;
            }
            
            try {
                const wb = XLSX.utils.book_new();
                
                // Summary sheet
                const summaryData = [
                    ['Laporan Periode', formatDate(startDate), '-', formatDate(endDate)],
                    ['Total Pendapatan', reportData.summary?.total_revenue || 0],
                    ['Total Transaksi', reportData.summary?.total_transactions || 0],
                    ['Pengujian Selesai', reportData.summary?.completed_tests || 0],
                    ['Perusahaan Aktif', reportData.summary?.active_clients || 0]
                ];
                const wsSummary = XLSX.utils.aoa_to_sheet(summaryData);
                XLSX.utils.book_append_sheet(wb, wsSummary, 'Summary');
                
                // Transactions sheet
                if (reportData.transactions && reportData.transactions.length > 0) {
                    const transactionData = reportData.transactions.map(t => [
                        formatDate(t.date),
                        t.reference,
                        t.company,
                        t.description,
                        t.category,
                        t.volume,
                        t.amount
                    ]);
                    transactionData.unshift(['Tanggal', 'No. Referensi', 'Perusahaan', 'Uraian', 'Kategori', 'Volume', 'Nilai']);
                    const wsTransactions = XLSX.utils.aoa_to_sheet(transactionData);
                    XLSX.utils.book_append_sheet(wb, wsTransactions, 'Transaksi');
                }
                
                // Save file
                XLSX.writeFile(wb, `laporan_${startDate}_${endDate}.xlsx`);
            } catch (error) {
                console.error('Export error:', error);
                showAlert('Gagal export Excel', 'danger');
            }
        }

        function exportTableToExcel() {
            if (!reportData || !reportData.transactions || reportData.transactions.length === 0) {
                showAlert('Tidak ada data untuk diexport', 'warning');
                return;
            }
            
            try {
                const transactionData = reportData.transactions.map(t => [
                    formatDate(t.date),
                    t.reference,
                    t.company,
                    t.description,
                    t.category,
                    t.volume,
                    t.amount
                ]);
                
                const ws = XLSX.utils.aoa_to_sheet([
                    ['Tanggal', 'No. Referensi', 'Perusahaan', 'Uraian', 'Kategori', 'Volume', 'Nilai'],
                    ...transactionData
                ]);
                
                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, 'Transaksi');
                XLSX.writeFile(wb, `transaksi_${startDate}_${endDate}.xlsx`);
            } catch (error) {
                console.error('Export error:', error);
                showAlert('Gagal export Excel', 'danger');
            }
        }

        async function exportToPDF() {
            if (!reportData) {
                showAlert('Tidak ada data untuk diexport', 'warning');
                return;
            }
            
            if (typeof window.jspdf === 'undefined') {
                showAlert('Library jsPDF tidak tersedia', 'danger');
                return;
            }
            
            try {
                const { jsPDF } = window.jspdf;
                const doc = new jsPDF();
                
                // Title
                doc.setFontSize(18);
                doc.text('Laporan UPTD Lab', 14, 22);
                
                doc.setFontSize(11);
                doc.text(`Periode: ${formatDate(startDate)} - ${formatDate(endDate)}`, 14, 32);
                
                // Summary
                doc.setFontSize(12);
                doc.text('Ringkasan', 14, 45);
                
                doc.setFontSize(10);
                doc.text(`Total Pendapatan: ${formatRupiah(reportData.summary?.total_revenue || 0)}`, 14, 55);
                doc.text(`Total Transaksi: ${reportData.summary?.total_transactions || 0}`, 14, 62);
                doc.text(`Pengujian Selesai: ${reportData.summary?.completed_tests || 0}`, 14, 69);
                
                // Transactions table
                if (reportData.transactions && reportData.transactions.length > 0) {
                    doc.autoTable({
                        startY: 80,
                        head: [['Tanggal', 'Referensi', 'Perusahaan', 'Uraian', 'Nilai']],
                        body: reportData.transactions.map(t => [
                            formatDate(t.date),
                            t.reference,
                            t.company,
                            t.description,
                            formatRupiah(t.amount)
                        ])
                    });
                }
                
                doc.save(`laporan_${startDate}_${endDate}.pdf`);
            } catch (error) {
                console.error('Export error:', error);
                showAlert('Gagal export PDF', 'danger');
            }
        }

        // ==================== HELPER FUNCTIONS ====================
        function formatDate(dateString) {
            if (!dateString) return '-';
            try {
                const date = new Date(dateString);
                const months = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
                return `${date.getDate()} ${months[date.getMonth()]} ${date.getFullYear()}`;
            } catch {
                return '-';
            }
        }

        function formatDateTime(dateString) {
            if (!dateString) return '-';
            try {
                const date = new Date(dateString);
                return formatDate(dateString) + ' ' + 
                    String(date.getHours()).padStart(2, '0') + ':' + 
                    String(date.getMinutes()).padStart(2, '0');
            } catch {
                return '-';
            }
        }

        function formatDateForInput(date) {
            return date.toISOString().split('T')[0];
        }

        function formatRupiah(number) {
            if (number === undefined || number === null) return 'Rp 0';
            return new Intl.NumberFormat('id-ID', {
                style: 'currency',
                currency: 'IDR',
                minimumFractionDigits: 0
            }).format(number);
        }

        function showLoading(show) {
            const overlay = document.getElementById('loadingOverlay');
            if (overlay) overlay.style.display = show ? 'flex' : 'none';
        }

        function showAlert(message, type) {
            const alertDiv = document.getElementById('alertMessage');
            if (!alertDiv) return;
            
            alertDiv.style.display = 'block';
            alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" onclick="this.parentElement.style.display='none'"></button>
            `;
            
            setTimeout(() => {
                alertDiv.style.display = 'none';
            }, 5000);
        }

        // ==================== INITIALIZE ====================
        document.addEventListener('DOMContentLoaded', () => {
            initializeDates();
            
            // Set default period label
            updatePeriodLabel();
            
            // Load data
            loadReportData(true);
            
            // Auto refresh setiap 5 menit
            const refreshInterval = setInterval(() => loadReportData(false), 300000);
            
            // Cleanup interval on page unload
            window.addEventListener('beforeunload', () => {
                clearInterval(refreshInterval);
                if (loadingTimeout) clearTimeout(loadingTimeout);
            });
        });
    </script>
