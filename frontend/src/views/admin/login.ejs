<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - UPTD Lab</title>
    <link rel="icon" type="image/png" href="/img/logo.png">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>

<body class="login-body">

    <div class="login-card">

        <!-- Header -->
        <div class="auth-icon-wrapper">
            <img src="/img/logo-banten.png" alt="Logo Banten" style="width: 100%; height: auto;">
        </div>
        <h2 class="auth-title">Login Administrator</h2>
        <p class="auth-subtitle">Bahan Konstruksi Bangunan &amp; Informasi Konstruksi</p>

        <!-- Alert JS-injected -->
        <div id="alertContainer"></div>

        <!-- Form -->
        <form id="loginForm">

            <div class="form-group">
                <label class="form-label" for="email">Alamat Email</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope icon-start"></i>
                    <input type="email" id="email" name="email" class="form-input" placeholder="admin@uptd.gov.id"
                        required autocomplete="email">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <div class="input-wrapper has-icon-end">
                    <i class="fas fa-lock icon-start"></i>
                    <input type="password" id="password" name="password" class="form-input"
                        placeholder="masukkan password" required autocomplete="current-password">
                    <i class="fas fa-eye-slash icon-end" id="togglePasswordIcon" style="cursor: pointer;"
                        onclick="togglePassword()"></i>
                </div>
                <div class="forgot-row">
                    <a href="#" onclick="showForgotPassword(event)">Lupa Password?</a>
                </div>
            </div>

            <button type="submit" class="btn-auth-base btn-action-login btn-full" id="loginButton">
                <span class="button-text" id="buttonText">Masuk</span>
                <span class="button-loader" id="buttonSpinner" style="display: none;">
                    <i class="fas fa-spinner fa-spin"></i> Memproses...
                </span>
            </button>

        </form>

        <div class="auth-footer" style="margin-top: 30px;">
            Gunakan akun administrator yang telah terdaftar.<br>
            © 2026 Pengujian Bahan Konstruksi Bangunan &amp; Informasi Konstruksi Provinsi Banten.
        </div>
    </div>

    <!-- Login JavaScript -->
    <script src="/js/admin/login.js"></script>
</body>

</html>