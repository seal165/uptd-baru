<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body>
    
    <div class="app-wrapper">
        <%- include('partials/sidebar', { page: 'skrd' }) %>

        <main class="main-content">
            <%- include('partials/top-navbar', { pageTitle: 'Manajemen SKRD' }) %>

            <div class="content-body">
                <!-- Alert Message -->
                <div id="alertMessage" class="alert alert-dismissible fade show" style="display: none;"></div>

                <!-- Header Section -->
                <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-bold text-dark m-0">Manajemen SKRD</h4>
                        <p class="text-muted small m-0">Monitoring tagihan retribusi dan status pembayaran.</p>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="row g-3 mb-4" id="statsCards">
                    <!-- Akan diisi JavaScript -->
                    <div class="col-md-4">
                        <div class="card-custom h-100">
                            <div class="skeleton-loader skeleton-text"></div>
                            <div class="skeleton-loader skeleton-text w-50"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card-custom h-100">
                            <div class="skeleton-loader skeleton-text"></div>
                            <div class="skeleton-loader skeleton-text w-50"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card-custom h-100">
                            <div class="skeleton-loader skeleton-text"></div>
                            <div class="skeleton-loader skeleton-text w-50"></div>
                        </div>
                    </div>
                </div>

                <!-- Custom Style for Filters -->
                

                <!-- Filter & Search Section -->
                <div class="mb-2">
                    <div class="d-flex align-items-center gap-2 overflow-auto filter-container py-2" style="white-space: nowrap;">
                        <!-- Search -->
                        <div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-3 filter-pill" style="min-width: 250px;">
                            <i class="fas fa-search text-muted me-2" style="font-size: 0.85rem;"></i>
                            <input type="text" class="form-control form-control-sm bg-transparent border-0 shadow-none px-0 py-0 m-0" id="searchInput" placeholder="Cari ID Pengajuan, Perusahaan..." style="font-size: 0.85rem;">
                        </div>
                        
                        <!-- Filter Tanggal -->
                        <div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-3 filter-pill">
                            <span class="text-muted fw-bold me-1" style="font-size: 0.85rem;">Periode:</span>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 shadow-none px-0 py-0 m-0 text-muted" id="startDateFilter" onchange="applyFilter()" style="font-size: 0.85rem; width: 100px;">
                            <span class="text-muted mx-1" style="font-size: 0.85rem;">-</span>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 shadow-none px-0 py-0 m-0 text-muted" id="endDateFilter" onchange="applyFilter()" style="font-size: 0.85rem; width: 100px;">
                        </div>
                        
                        <!-- Filter Status -->
                        <div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-3 filter-pill">
                            <select class="form-select form-select-sm bg-transparent border-0 shadow-none text-muted ps-0 py-0 m-0" id="statusSelect" style="width: 150px; cursor: pointer; font-size: 0.85rem;" onchange="applyFilter()">
                                <option value="">Semua Status</option>
                                <option value="Menunggu Verifikasi">Menunggu Verifikasi</option>
                                <option value="Pengecekan Sampel">Pengecekan Sampel</option>
                                <option value="Belum Bayar">Belum Bayar</option>
                                <option value="Menunggu SKRD Upload">Menunggu SKRD</option>
                                <option value="Belum Lunas">Belum Lunas</option>
                                <option value="Lunas">Lunas</option>
                                <option value="Sedang Diuji">Sedang Diuji</option>
                                <option value="Selesai">Selesai</option>
                                <option value="Dibatalkan">Dibatalkan</option>
                            </select>
                        </div>

                        <!-- Export Button -->
                        <div class="ms-auto">
                            <button class="btn btn-sm btn-success fw-bold rounded-pill px-3 filter-pill d-flex align-items-center border-0" onclick="exportToExcel()">
                                <i class="fas fa-file-excel me-1"></i> Export Excel
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Main Table -->
                <div class="card-custom p-0 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="text-muted small text-uppercase fw-bold">
                                    <th class="ps-4 py-3">No. Invoice</th>
                                    <th class="py-3">Perusahaan & Layanan</th>
                                    <th class="py-3">Tanggal Terbit</th>
                                    <th class="py-3">Jatuh Tempo</th>
                                    <th class="py-3 text-end">Total Tagihan</th>
                                    <th class="py-3">Status</th>
                                    <th class="py-3 text-end">Sisa</th>
                                    <th class="text-end pe-4 py-3">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="invoicesTableBody">
                                <!-- Loading State -->
                                <tr id="loadingRow">
                                    <td colspan="8" class="text-center py-5">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                        <p class="text-muted mt-2">Memuat data...</p>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div class="card-footer bg-white border-top py-3 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <small class="text-muted" id="paginationInfo"></small>
                        <nav>
                            <ul class="pagination pagination-sm mb-0" id="pagination">
                                <!-- Akan diisi JavaScript -->
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Toast Container -->
    <div id="toastContainer" class="toast-notification"></div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="/js/admin/skrd.js"></script>
</body>
</html>