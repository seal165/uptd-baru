<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body>
    <div class="app-wrapper">
        <%- include('partials/sidebar', { page: 'kuisioner' }) %>

        <main class="main-content">
            <%- include('partials/top-navbar', { pageTitle: 'Manajemen Kuisioner' }) %>

            <div class="content-body">
                <!-- Alert Message -->
                <div id="alertMessage" class="alert alert-dismissible fade show" style="display: none;"></div>

                <!-- Header -->
                <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-bold text-dark m-0">Manajemen Kuisioner</h4>
                        <p class="text-muted small m-0">Kelola pertanyaan dan lihat hasil survei kepuasan pelanggan.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <!-- FILTER PERIODE TANGGAL -->
                        <div class="d-flex align-items-center gap-2">
                            <input type="date" class="form-control form-control-sm" id="startDate" style="width: 140px;">
                            <span class="text-muted">-</span>
                            <input type="date" class="form-control form-control-sm" id="endDate" style="width: 140px;">
                            <button class="btn btn-sm btn-outline-primary" onclick="applyDateFilter()" title="Terapkan Filter">
                                <i class="fas fa-filter"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" onclick="resetDateFilter()" title="Reset Filter">
                                <i class="fas fa-undo"></i>
                            </button>
                        </div>
                        
                        <!-- TOMBOL EXPORT -->
                        <button class="btn btn-success btn-sm" onclick="exportKuisioner()">
                            <i class="fas fa-file-excel me-2"></i>Export
                        </button>
                    </div>
                </div>

                <!-- Stats Overview -->
                <div class="row g-3 mb-4" id="statsOverview">
                    <div class="col-md-3">
                        <div class="stats-card text-center">
                            <div class="stats-number" id="totalResponden">0</div>
                            <div class="stats-label">Total Responden</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stats-card text-center">
                            <div class="stats-number" id="rataKeseluruhan">0.0</div>
                            <div class="stats-label">Rata-rata Kepuasan</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stats-card text-center">
                            <div class="stats-number" id="nilaiTertinggi">0.0</div>
                            <div class="stats-label">Nilai Tertinggi</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stats-card text-center">
                            <div class="stats-number" id="nilaiTerendah">0.0</div>
                            <div class="stats-label">Nilai Terendah</div>
                        </div>
                    </div>
                    <div class="mt-3 text-end">
                        <span id="previewTotalNilai" class="fw-bold"></span>
                    </div>
                </div>

                <!-- Charts Row -->
                <div class="row g-3 mb-4">
                    <div class="col-md-8">
                        <div class="chart-container">
                            <h6 class="fw-bold mb-3">Rata-rata Nilai per Kriteria</h6>
                            <div style="position: relative; height: 300px; width: 100%;">
                                <canvas id="kriteriaChart"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="chart-container">
                            <h6 class="fw-bold mb-3">Distribusi Nilai</h6>
                            <div style="position: relative; height: 300px; width: 100%;">
                                <canvas id="distribusiChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Search Section -->
                <div class="mb-4">
                    <div class="d-flex align-items-center gap-2 py-2 overflow-auto hide-scrollbar" style="white-space: nowrap;">
                        <!-- Search -->
                        <div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-4" style="flex-grow: 1; min-width: 300px; height: 46px; border: 1px solid #f8f9fa;">
                            <i class="fas fa-search text-muted me-2" style="font-size: 0.95rem;"></i>
                            <input type="text" class="form-control bg-transparent border-0 shadow-none px-0 m-0 w-100" id="searchInput" placeholder="Cari nama pemohon atau instansi..." style="font-size: 0.95rem;">
                        </div>
                    </div>
                </div>

                <!-- Kuisioner Table -->
                <div class="card-custom p-0 overflow-hidden mb-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3">No</th>
                                    <th class="py-3">Pemohon</th>
                                    <th class="py-3">Instansi</th>
                                    <th class="py-3">Tanggal</th>
                                    <th class="py-3 text-center">Nilai</th>
                                    <th class="py-3">Saran</th>
                                    <th class="text-end pe-4 py-3">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="kuisionerTableBody">
                                <tr id="loadingRow">
                                    <td colspan="7" class="text-center py-5">
                                        <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
                                        <p class="text-muted">Memuat data...</p>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div class="d-flex flex-wrap justify-content-between align-items-center p-3 border-top bg-white">
                        <small class="text-muted" id="paginationInfo"></small>
                        <nav>
                            <ul class="pagination pagination-sm mb-0" id="pagination"></ul>
                        </nav>
                    </div>
                </div>

                <!-- Daftar Pertanyaan Aktif -->
                <div class="card-custom border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
                        <h6 class="fw-bold mb-0"><i class="fas fa-list me-2"></i>Daftar Pertanyaan Aktif</h6>
                        <div>
                            <span class="badge bg-primary me-2" id="totalQuestions">0 Pertanyaan</span>
                            <button class="btn btn-sm btn-primary" onclick="tambahPertanyaan()" id="btnTambahPertanyaan">
                                <i class="fas fa-plus me-1"></i>Tambah Pertanyaan
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th width="70">No</th>
                                        <th>Pertanyaan</th>
                                        <th width="100">Status</th>
                                        <th width="150" class="text-end">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody id="questionsTableBody">
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">
                                            <i class="fas fa-list fa-2x mb-2"></i>
                                            <p>Belum ada pertanyaan</p>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Modal Tambah/Edit Pertanyaan -->
    <div class="modal" id="questionModal" tabindex="-1" data-bs-backdrop="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="questionModalTitle">Tambah Pertanyaan</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="questionForm">
                        <input type="hidden" id="questionId">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Kriteria Penilaian <span class="text-danger">*</span></label>
                            <textarea class="form-control" id="questionText" rows="3" placeholder="Masukkan teks pertanyaan..." required></textarea>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nomor Urut</label>
                            <input type="number" class="form-control" id="questionOrder" min="1" placeholder="Otomatis jika dikosongkan">
                            <small class="text-muted">Kosongkan untuk urutan otomatis</small>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Status</label>
                            <select class="form-select" id="questionStatus">
                                <option value="active">Aktif</option>
                                <option value="inactive">Nonaktif</option>
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Batal</button>
                    <button type="button" class="btn btn-danger" id="deleteQuestionBtn" style="display: none;" onclick="confirmDeleteQuestion()">
                        <i class="fas fa-trash me-1"></i>Hapus
                    </button>
                    <button type="button" class="btn btn-primary" onclick="saveQuestion()">Simpan</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Preview Kuisioner -->
    <div class="modal preview-modal" id="previewModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Detail Kuisioner</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p class="mb-1 text-muted">Nama Pemohon</p>
                            <h6 id="previewNamaPemohon" class="fw-bold">-</h6>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1 text-muted">Instansi</p>
                            <h6 id="previewInstansi" class="fw-bold">-</h6>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1 text-muted">Telepon</p>
                            <h6 id="previewTelepon" class="fw-bold">-</h6>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1 text-muted">Tanggal</p>
                            <h6 id="previewTanggal" class="fw-bold">-</h6>
                        </div>
                    </div>
                    
                    <h6 class="fw-bold mb-3">Nilai Penilaian</h6>
                    <div class="table-responsive">
                        <table class="preview-table">
                            <thead>
                                <tr>
                                    <th>No</th>
                                    <th>Kriteria</th>
                                    <th>Nilai</th>
                                </tr>
                            </thead>
                            <tbody id="previewNilaiBody">
                                <!-- Akan diisi JavaScript -->
                            </tbody>
                        </table>
                    </div>
                    
                    <div class="mt-4">
                        <p class="mb-1 text-muted">Saran / Komentar</p>
                        <div class="bg-light p-3 rounded" id="previewSaran">
                            -
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" onclick="downloadKuisionerPDF()">
                        <i class="fas fa-file-pdf me-1"></i>Download PDF
                    </button>
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Tutup</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart JS -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- jsPDF untuk download PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <!-- AutoTable untuk tabel PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Custom JS -->
    <script src="/js/admin/kuisioner.js"></script>
</body>
</html>