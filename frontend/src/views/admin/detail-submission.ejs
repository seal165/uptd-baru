<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body>
    <div class="app-wrapper">
        <%- include('partials/sidebar', { page: 'submissions' }) %>

        <main class="main-content">
            <%- include('partials/top-navbar', { pageTitle: 'Detail Pengajuan', backLink: { url: '/admin/submissions', text: 'Kembali' } }) %>

            <div class="content-body">
                <!-- Loading Overlay -->
                <div id="loadingOverlay" class="loading-overlay">
                    <div class="loading-spinner">
                        <div class="spinner-border text-primary mb-3" role="status"></div>
                        <p class="text-muted">Memuat data...</p>
                    </div>
                </div>

                <!-- Toast Container -->
                <div id="toastContainer" class="toast-notification"></div>

                
                <!-- Header dengan ID dan Status -->
                <div class="card-custom mb-4 p-3 border-0 shadow-sm d-flex flex-column flex-md-row align-items-md-center justify-content-between">
                    <div class="mb-3 mb-md-0">
                        <small class="text-muted fw-bold d-block mb-1">ID Pengajuan</small>
                        <h4 class="fw-bold m-0 text-dark" id="submissionId">#APP-<span id="idValue"></span></h4>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-light text-secondary px-3 py-2 border rounded-3 d-flex align-items-center shadow-sm" id="dateBadge" style="font-size: 0.85rem;"></span>
                        <span class="badge px-3 py-2 rounded-3 d-flex align-items-center shadow-sm" id="statusBadge" style="font-size: 0.85rem;"></span>
                    </div>
                </div>

                <!-- Alert untuk pesan error -->
                <div id="alertMessage" class="alert" style="display: none;"></div>

                <div class="row g-4">
                    <!-- KOLOM KIRI (8 kolom) -->
                    <div class="col-md-8">
                        <!-- Informasi Perusahaan -->
                        <div class="card-custom mb-4" id="companyInfo">
                            <h6 class="fw-bold text-uppercase text-muted small mb-3 border-bottom pb-3">
                                <i class="far fa-building me-2"></i>Informasi Perusahaan
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <small class="text-muted d-block mb-1">Nama Perusahaan</small>
                                    <span class="fw-bold text-dark" id="companyName">-</span>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted d-block mb-1">Nama PIC</small>
                                    <span class="fw-bold text-dark" id="picName">-</span>
                                </div>
                                <div class="col-12">
                                    <small class="text-muted d-block mb-1">Alamat Lengkap</small>
                                    <span class="text-dark" id="companyAddress">-</span>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted d-block mb-1">Email Kontak</small>
                                    <span class="text-dark" id="picEmail">-</span>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted d-block mb-1">Telepon</small>
                                    <span class="text-dark" id="picPhone">-</span>
                                </div>
                            </div>
                        </div>

                        <!-- Detail Material & Layanan - HAPUS TOTAL ITEM -->
                        <div class="card-custom mb-4" id="serviceDetails">
                            <h6 class="fw-bold text-uppercase text-muted small mb-3 border-bottom pb-3">
                                <i class="fas fa-cubes me-2"></i>Detail Material & Layanan
                            </h6>
                            <div class="d-flex flex-wrap gap-5 mb-4">
                                <div>
                                    <small class="text-muted d-block mb-1">Kategori</small>
                                    <div class="fw-bold text-primary" id="category">
                                        <i class="fas fa-flask me-2"></i>-
                                    </div>
                                </div>
                                <div>
                                    <small class="text-muted d-block mb-1">Jenis Material</small>
                                    <div class="fw-bold text-dark" id="testType">-</div>
                                </div>
                                <!-- 🔥 TOTAL ITEM DIHAPUS -->
                            </div>
                            
                            <div class="table-responsive">
                                <table class="table table-bordered align-middle mb-0">
                                    <thead class="bg-light">
                                        <tr class="text-muted small text-uppercase">
                                            <th class="py-2">Spesifikasi Item</th>
                                            <th width="100" class="text-center py-2">Jumlah</th>
                                            <th width="100" class="py-2">Satuan</th>
                                            <th width="150" class="py-2">Harga</th>
                                            <th width="150" class="py-2">Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody id="itemsTableBody">
                                        <!-- Akan diisi JavaScript -->
                                        <tr>
                                            <td colspan="5" class="text-center py-4">
                                                <div class="spinner-border spinner-border-sm text-primary"></div>
                                                Memuat item...
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Catatan dari User -->
                        <div class="card-custom mb-4">
                            <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                                <h6 class="fw-bold text-uppercase text-muted small m-0">
                                    <i class="fas fa-user me-2"></i>Catatan dari Pemohon
                                </h6>
                            </div>
                            <div class="p-3 bg-light rounded text-muted">
                                <p id="userNotes" class="mb-0">-</p>
                            </div>
                        </div>


                        <!-- 🔥 DOKUMEN FORMULIR PENGAJUAN - TANPA PREVIEW -->
                        <div class="card-custom mb-4">
                            <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                                <h6 class="fw-bold text-uppercase text-muted small m-0">
                                    <i class="fas fa-file-alt me-2"></i>Formulir Pengajuan Pengujian
                                </h6>
                                <button class="btn btn-sm btn-outline-success" onclick="downloadForm()" id="downloadFormBtn">
                                    Download Formulir
                                </button>
                            </div>
                            
                            <!-- 🔥 PREVIEW FORMULIR DIHAPUS -->
                            <!-- <div class="form-preview mb-3">
                                <pre id="formPreview">Memuat formulir...</pre>
                            </div> -->
                        </div>

                        <!-- 🔥 DOKUMEN PENDUKUNG Wajib -->
                        <div class="card-custom mb-4" id="dokumenWajibSection">
                            <div class="border-bottom pb-3 mb-3">
                                <h6 class="fw-bold text-uppercase text-muted small m-0">
                                    <i class="fas fa-file-pdf me-2 text-danger"></i>Dokumen Pendukung (Wajib)
                                </h6>
                            </div>
                            
                            <!-- Surat Permohonan -->
                            <div class="document-card p-3 border rounded mb-3 document-required">
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded text-danger d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px; border: 1px solid #dee2e6;">
                                        <i class="fas fa-file-pdf fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="fw-bold">Surat Permohonan dari Perusahaan</span>
                                            <span class="badge" style="background-color: #dc3545; color: white; font-size: 0.7rem;">Wajib</span>
                                        </div>
                                        <small class="text-muted d-block mt-1" id="suratPermohonanInfo">Belum diupload</small>
                                    </div>
                                    <div id="suratPermohonanActions">
                                        <!-- Akan diisi JavaScript -->
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Scan KPT -->
                            <div class="document-card p-3 border rounded mb-3 document-required">
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded text-danger d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px; border: 1px solid #dee2e6;">
                                        <i class="fas fa-file-pdf fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="fw-bold">Scan KTP (Kartu Pemilik/Tanda Terdaftar)</span>
                                            <span class="badge" style="background-color: #dc3545; color: white; font-size: 0.7rem;">Wajib</span>
                                        </div>
                                        <small class="text-muted d-block mt-1" id="scanKTPInfo">Belum diupload</small>
                                    </div>
                                    <div id="scanKTPActions">
                                        <!-- Akan diisi JavaScript -->
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 🔥 DOKUMEN PENDUKUNG TAMBAHAN -->
                        <div class="card-custom mb-4" id="dokumenTambahanSection">
                            <div class="border-bottom pb-3 mb-3">
                                <h6 class="fw-bold text-uppercase text-muted small m-0">
                                    <i class="fas fa-folder-open me-2 text-primary"></i>Dokumen Pendukung Tambahan
                                </h6>
                            </div>
                            
                            <div class="document-card p-3 border rounded mb-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded text-primary d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px; border: 1px solid #dee2e6;">
                                        <i class="fas fa-file-alt fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="fw-bold">Dokumen Tambahan / Lampiran</span>
                                            <span class="badge bg-secondary" style="color: white; font-size: 0.7rem;">Opsional</span>
                                        </div>
                                        <small class="text-muted d-block mt-1" id="dokumenTambahanInfo">Belum diupload</small>
                                    </div>
                                    <div id="dokumenTambahanActions">
                                        <!-- Akan diisi JavaScript -->
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                    </div>

                    <!-- KOLOM KANAN (4 kolom) - PERBAIKI UPLOAD -->
                    <div class="col-md-4">
                        <!-- Pusat Aksi -->
                        <div class="card-custom h-auto mb-4 border-top border-3 border-primary position-relative overflow-hidden">
                            <div class="d-flex align-items-center mb-4">
                                <div class="bg-primary-subtle p-2 rounded me-2 text-primary">
                                    <i class="fas fa-sliders-h"></i>
                                </div>
                                <h6 class="fw-bold m-0">Pusat Aksi</h6>
                            </div>
                            
                            <form id="updateForm">
                                <input type="hidden" id="submissionId" value="">
                                
                                <div class="mb-3">
                                    <label class="small fw-bold mb-1 text-muted">Update Status</label>
                                    <select class="form-select shadow-none" id="statusSelect" required>
                                        <!-- 🔥 GUNAKAN VALUE LANGSUNG, BUKAN MAPPING -->
                                        <option value="Menunggu Verifikasi">Menunggu Verifikasi</option>
                                        <option value="Pengecekan Sampel">Pengecekan Sampel</option>
                                        <option value="Belum Bayar">Belum Bayar</option>
                                        <option value="Menunggu SKRD Upload">Menunggu SKRD Upload</option>
                                        <option value="Belum Lunas">Belum Lunas</option>
                                        <option value="Lunas">Lunas</option>
                                        <option value="Sedang Diuji">Sedang Diuji</option>
                                        <option value="Selesai">Selesai</option>
                                        <option value="Dibatalkan">Dibatalkan</option>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="small fw-bold mb-1 text-muted">Jadwal Sampling / Uji</label>
                                    <input type="date" class="form-control shadow-none" id="testDate">
                                </div>

                                <!-- Upload area tetap -->
                                <div class="mb-3">
                                      <label class="small fw-bold mb-1 text-muted">Unggah Hasil (Sertifikat)</label>
                                      <div class="upload-area rounded-3 p-4 text-center bg-light position-relative" 
                                          id="uploadArea"
                                          style="border-style: dashed !important; cursor: pointer;">
                                          
                                          <div id="uploadContent">
                                              <i class="fas fa-cloud-upload-alt text-primary fa-2x mb-2"></i>
                                              <div class="small text-muted fw-bold">Klik atau drag & drop file</div>
                                              <small class="text-muted d-block" style="font-size: 0.7rem;">
                                                  PDF/JPG, maksimal <%= locals.settings?.max_upload_size || 5 %>MB
                                              </small>
                                          </div>
                                          
                                          <div id="uploadLoading" style="display: none;" class="py-2">
                                              <div class="spinner-border spinner-border-sm text-primary mb-2"></div>
                                              <small class="d-block text-muted mt-1">Mengupload...</small>
                                          </div>
                                          
                                          <input type="file" class="position-absolute top-0 start-0 w-100 h-100 opacity-0" 
                                              id="fileInput" accept=".pdf,.jpg,.jpeg,.png" style="cursor: pointer;">
                                      </div>
                                      <div id="filePreview" class="mt-2" style="display: none;"></div>
                                  </div>

                                <div class="mb-4">
                                    <label class="small fw-bold mb-1 text-muted">Catatan Internal</label>
                                    <textarea class="form-control shadow-none" rows="3" 
                                            id="internalNotes" placeholder="Tulis catatan untuk tim..."></textarea>
                                </div>

                                <div class="d-flex flex-column gap-2 mt-4">
                                    <button type="submit" form="updateForm" class="btn btn-primary fw-bold text-center" id="updateBtn">
                                        <span id="updateBtnText">Simpan Perubahan</span>
                                        <span id="updateBtnSpinner" style="display: none;">
                                            <span class="spinner-border spinner-border-sm me-2"></span>Menyimpan...
                                        </span>
                                    </button>
                                    <button type="button" class="btn btn-outline-danger fw-bold text-center" onclick="cancelSubmission()">
                                        <i class="fas fa-times me-2"></i> Batalkan Pengajuan
                                    </button>
                                </div>
                            </form>
                        </div>
                        
                        <!-- Timeline Status -->
                        <div class="card-custom h-auto mb-4">
                            <h6 class="fw-bold mb-4">Status Progress</h6>
                            
                            <div class="status-timeline" id="statusTimeline">
                                <!-- Akan diisi JavaScript -->
                                <div class="text-center py-3">
                                    <div class="spinner-border spinner-border-sm text-primary"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- 🔥 FLOATING BUTTON - Lihat Detail Transaksi -->
    <button class="btn btn-primary floating-btn" onclick="viewTransactionDetail()" id="transactionBtn">
        Lihat Detail Transaksi
    </button>

    <!-- Data Container -->
    <div id="submission-data" 
         data-id="<%= submissionId %>"
         style="display: none;"></div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- External Libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
    
    <!-- Custom JavaScript -->
    <script src="/js/admin/detail-submission.js"></script>
</body>
</html>