<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body>

    <div class="app-wrapper">
        <%- include('partials/sidebar', { page: 'users' }) %>

        <main class="main-content">
            <%- include('partials/top-navbar', { pageTitle: 'Data Pemohon' }) %>

            <div class="content-body">
                <div class="container-fluid">
                    <!-- Alert Message -->
                    <div id="alertMessage" class="alert alert-dismissible fade show" style="display: none;"></div>

                    <!-- Header -->
                    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                        <div>
                            <p class="text-muted small m-0">Kelola akun perusahaan dan pemohon perorangan.</p>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-success btn-sm text-white shadow-sm" onclick="exportToExcel()">
                                <i class="fas fa-file-excel me-2"></i>Export Data
                            </button>
                        </div>
                    </div>

                    <!-- Top Actions Row -->
                    <div class="row g-3 mb-4 align-items-stretch">
                        <!-- Stats Card -->
                        <div class="col-md-3" id="statsCards">
                            <!-- Akan diisi JavaScript -->
                        </div>

                        <!-- Filter Section -->
                        <div class="col-md-9">
                            <div class="card-custom h-100 d-flex flex-column justify-content-center p-3">
                                <!-- Quick Status Filters -->
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <span class="badge bg-light text-dark filter-badge active" data-role="">Semua</span>
                                    <span class="badge badge-soft-primary filter-badge" data-role="pelanggan">Pelanggan</span>
                                    <span class="badge badge-soft-success filter-badge" data-role="admin">Admin</span>
                                </div>

                                <!-- Search -->
                                <div class="w-100">
                                    <div class="d-flex align-items-center bg-light border rounded-pill px-3">
                                        <i class="fas fa-search text-muted me-2" style="font-size: 0.85rem;"></i>
                                        <input type="text" class="form-control form-control-sm bg-transparent border-0 shadow-none px-0 py-2 m-0 w-100" id="searchInput" placeholder="Cari pemohon/perusahaan..." style="font-size: 0.85rem;">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Users Table -->
                    <div class="card-custom p-0 overflow-hidden mb-3">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4 py-3" style="width: 50px;">
                                            <input type="checkbox" class="form-check-input" id="selectAll">
                                        </th>
                                        <th class="py-3">Identitas Pemohon</th>
                                        <th class="py-3">Kontak</th>
                                        <th class="py-3">Status Akun</th>
                                        <th class="py-3">Terdaftar Sejak</th>
                                        <th class="py-3">Total Transaksi</th>
                                        <th class="text-end pe-4 py-3">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody id="usersTableBody">
                                    <!-- Loading State -->
                                    <tr id="loadingRow">
                                        <td colspan="7" class="text-center py-5">
                                            <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
                                                <span class="visually-hidden">Loading...</span>
                                            </div>
                                            <p class="text-muted mt-2">Memuat data pemohon...</p>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Empty State -->
                        <div id="emptyState" style="display: none;">
                            <div class="text-center p-5">
                                <i class="fas fa-users fa-4x text-muted mb-3"></i>
                                <p class="text-muted">Belum ada data pemohon.</p>
                            </div>
                        </div>
                        
                        <!-- Pagination -->
                        <div class="d-flex flex-wrap justify-content-between align-items-center p-3 border-top bg-white">
                            <small class="text-muted" id="paginationInfo"></small>
                            <nav>
                                <ul class="pagination pagination-sm mb-0" id="pagination">
                                    <!-- Akan diisi JavaScript -->
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Detail User Modal -->
    <div class="modal fade" id="detailModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Detail Pemohon</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-4 text-center mb-3">
                            <div class="avatar-initials mx-auto mb-2" id="detailAvatar" style="width: 80px; height: 80px; font-size: 24px; background-color: #4361ee; color: white;"></div>
                            <h5 id="detailName"></h5>
                            <span class="badge" id="detailStatus"></span>
                        </div>
                        <div class="col-md-8">
                            <table class="table table-borderless">
                                <tr>
                                    <td width="120" class="text-muted">Email</td>
                                    <td><strong id="detailEmail"></strong></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Telepon</td>
                                    <td><strong id="detailPhone"></strong></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Perusahaan</td>
                                    <td><strong id="detailCompany"></strong></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Alamat</td>
                                    <td><strong id="detailAddress"></strong></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Terdaftar</td>
                                    <td><strong id="detailJoined"></strong></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Total Transaksi</td>
                                    <td><strong id="detailTransactions"></strong></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Total Pembayaran</td>
                                    <td><strong id="detailPayments"></strong></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- Riwayat Transaksi -->
                    <h6 class="fw-bold mt-4 mb-3">Riwayat Transaksi</h6>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Tanggal</th>
                                    <th>No. Pengajuan</th>
                                    <th>Layanan</th>
                                    <th>Status</th>
                                    <th>Nilai</th>
                                </tr>
                            </thead>
                            <tbody id="detailTransactionsBody">
                                <!-- Akan diisi JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Tutup</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="/js/admin/users.js"></script>
</body>
</html>