<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body class="bg-light">
    <div class="app-wrapper">
        <%- include('partials/sidebar', { page: 'users' }) %>

        <main class="main-content">
            <%- include('partials/top-navbar', { pageTitle: 'Detail Pemohon', backLink: { url: '/admin/users', text: 'Kembali' } }) %>

            <div class="content-body">
                <!-- Alert Message -->
                <div id="alertMessage" class="alert alert-dismissible fade show" style="display: none;"></div>

                
        <!-- Profile Card -->
        <div class="profile-card" id="profileCard">
            <!-- Akan diisi JavaScript -->
        </div>

        <!-- Stats Row -->
        <div class="row g-3 mb-4" id="statsRow">
            <!-- Akan diisi JavaScript -->
        </div>

        <!-- Submissions Table -->
        <div class="profile-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Riwayat Pengajuan</h5>
                <span class="text-muted small" id="submissionCount"></span>
            </div>
            
            <div class="table-responsive rounded border">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">No. Registrasi</th>
                            <th class="py-3">Jenis Uji</th>
                            <th class="py-3">Jenis Sample</th>
                            <th class="py-3">Nama Proyek</th>
                            <th class="py-3">Tanggal</th>
                            <th class="py-3">Status</th>
                            <th class="py-3">Total</th>
                            <th class="text-center pe-4 py-3">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="submissionsTableBody">
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <div class="spinner-border spinner-border-sm text-primary me-2"></div>
                                <span class="text-muted">Memuat data...</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <small class="text-muted" id="paginationInfo"></small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0" id="pagination">
                            <!-- Akan diisi JavaScript -->
                        </ul>
                    </nav>
                </div>
            </div>
            </div>
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="/js/admin/detail-user.js"></script>
</body>
</html>