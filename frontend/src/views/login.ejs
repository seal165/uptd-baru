<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - UPTD Pengujian</title>
    <link rel="icon" type="image/png" href="/img/logo.png">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <script src="/config.js"></script>    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body class="login-body">

    <div class="login-card">

        <!-- Header -->
        <div class="auth-icon-wrapper">
            <img src="/img/logo-banten.png" alt="Logo Banten" style="width: 100%; height: auto;">
        </div>
        <h2 class="auth-title">UPTD Pengujian</h2>
        <p class="auth-subtitle">Bahan Konstruksi Bangunan &amp; Informasi Konstruksi</p>

        <!-- Tabs -->
        <div class="auth-tabs">
            <a href="/login" class="auth-tab active">Login</a>
            <a href="/register" class="auth-tab">Register</a>
        </div>

        <!-- Alert: Error server -->
        <% if (locals.error) { %>
            <div class="alert-box alert-error">
                <i class="fas fa-exclamation-circle"></i>
                <span><%= error %></span>
            </div>
        <% } %>

        <!-- Alert: Sukses dari register -->
        <% if (locals.success) { %>
            <div class="alert-box alert-success">
                <i class="fas fa-check-circle"></i>
                <span><%= success %></span>
            </div>
        <% } %>

        <!-- Alert JS-injected -->
        <div id="alertContainer"></div>

        <!-- Form -->
        <form id="loginForm" method="POST" action="/auth/login">

            <div class="form-group">
                <label class="form-label" for="loginEmail">Alamat Email</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope icon-start"></i>
                    <input
                        type="email"
                        id="loginEmail"
                        name="email"
                        class="form-input"
                        placeholder="nama@instansi.com"
                        required
                        autocomplete="email"
                        value="<%= locals.formData ? formData.email : '' %>">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="loginPassword">Password</label>
                <div class="input-wrapper has-icon-end">
                    <i class="fas fa-lock icon-start"></i>
                    <input
                        type="password"
                        id="loginPassword"
                        name="password"
                        class="form-input"
                        placeholder="Masukkan password Anda"
                        required
                        autocomplete="current-password">
                    <i class="fas fa-eye-slash icon-end" id="togglePassword"></i>
                </div>
                <div class="forgot-row">
                    <a href="/forgot-password">Lupa Password?</a>
                </div>
            </div>

            <button type="submit" class="btn-auth-base btn-action-login btn-full" id="loginButton">
                <span class="button-text">Masuk</span>
                <span class="button-loader" style="display: none;">
                    <i class="fas fa-spinner fa-spin"></i> Memproses...
                </span>
            </button>

        </form>

        <div class="auth-footer">
            © 2026 Pengujian Bahan Konstruksi Bangunan &amp; Informasi Konstruksi Provinsi Banten.
        </div>
    </div>

    <script src="/js/auth.js"></script>
    <script>
        // ---- Toggle password ----
        (function () {
            const passwordInput = document.getElementById('loginPassword');
            const toggleIcon    = document.getElementById('togglePassword');
            if (!passwordInput || !toggleIcon) return;
            toggleIcon.addEventListener('click', function () {
                const isPassword = passwordInput.type === 'password';
                passwordInput.type = isPassword ? 'text' : 'password';
                toggleIcon.classList.toggle('fa-eye-slash', !isPassword);
                toggleIcon.classList.toggle('fa-eye', isPassword);
            });
        })();

        // ---- Alert helper ----
        function showAlert(type, message) {
            const container = document.getElementById('alertContainer');
            container.innerHTML = '';
            const div = document.createElement('div');
            div.className = `alert-box alert-${type}`;
            const icon = type === 'error' ? 'fa-exclamation-circle' : 'fa-check-circle';
            div.innerHTML = `<i class="fas ${icon}"></i><span>${message}</span>`;
            container.appendChild(div);
        }

        // ---- Fetch profil terbaru ----
        async function fetchLatestUserProfile(token, fallbackUser) {
            if (!token) return fallbackUser;
            try {
                const res = await fetch(`<%= typeof backendUrl !== 'undefined' ? backendUrl : 'http://localhost:5000' %>/api/users/profile/me`, {
                    method: 'GET',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    }
                });
                if (!res.ok) return fallbackUser;
                const result = await res.json();
                if (!result.success || !result.data) return fallbackUser;
                return {
                    ...fallbackUser,
                    ...result.data,
                    id: result.data.id || fallbackUser.id,
                    email: result.data.email || fallbackUser.email,
                    full_name: result.data.full_name || fallbackUser.full_name,
                    nama_instansi: result.data.nama_instansi || fallbackUser.nama_instansi || null,
                    role: result.data.role || fallbackUser.role,
                    avatar: result.data.avatar || fallbackUser.avatar || null
                };
            } catch (err) {
                console.warn('Gagal ambil profil terbaru:', err);
                return fallbackUser;
            }
        }

        // ---- Submit form ----
        document.getElementById('loginForm').addEventListener('submit', async function (e) {
            e.preventDefault();

            const email    = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            const btn      = document.getElementById('loginButton');
            const btnText  = btn.querySelector('.button-text');
            const btnLoad  = btn.querySelector('.button-loader');

            btnText.style.display = 'none';
            btnLoad.style.display = 'inline';
            btn.disabled = true;

            try {
                const res = await fetch('/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });
                const result = await res.json();

                if (result.success && result.data) {
                    const userData = result.data;
                    if (userData.token) localStorage.setItem('token', userData.token);

                    const latestUser = await fetchLatestUserProfile(userData.token, userData);
                    localStorage.setItem('user', JSON.stringify({
                        id: latestUser.id,
                        email: latestUser.email,
                        full_name: latestUser.full_name,
                        nama_instansi: latestUser.nama_instansi || null,
                        role: latestUser.role,
                        avatar: latestUser.avatar || null
                    }));

                    if (result.redirect) {
                        window.location.href = result.redirect;
                    } else if (latestUser.role === 'admin' || latestUser.role === 'petugas') {
                        window.location.href = '/admin/dashboard';
                    } else {
                        window.location.href = '/user/dashboard';
                    }
                } else {
                    btnText.style.display = 'inline';
                    btnLoad.style.display = 'none';
                    btn.disabled = false;
                    showAlert('error', result.message || 'Email atau password salah!');
                }
            } catch (err) {
                console.error('❌ Error:', err);
                btnText.style.display = 'inline';
                btnLoad.style.display = 'none';
                btn.disabled = false;
                showAlert('error', 'Terjadi kesalahan saat login. Silakan coba lagi.');
            }
        });

        // ---- Cek URL param ?registered=true ----
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('registered') === 'true') {
            showAlert('success', 'Registrasi berhasil! Silakan masuk dengan akun Anda.');
            window.history.replaceState({}, document.title, '/login');
        }
    </script>

</body>
</html>