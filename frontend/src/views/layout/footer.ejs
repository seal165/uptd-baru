<footer class="footer container" style="margin-top: 40px; padding: 40px 0; border-top: 1px solid #eee;">
    <div class="footer-row">
        
        <div class="footer-col-main">
            <p style="font-weight: 700; margin-bottom: 8px; color: #334155; line-height: 1.4; font-size: 1rem;">
                UPTD Pengujian Bahan Konstruksi Bangunan & Informasi Konstruksi
            </p>
            <p style="font-size: 0.85rem; color: #94a3b8; margin: 0;">
                © 2026 Pemerintah Provinsi Banten. Hak Cipta Dilindungi Undang-Undang.
            </p>
        </div>

        <div class="footer-col-contact">
            <div style="display: flex; gap: 12px;">
                <i class="fas fa-map-marker-alt" style="margin-top: 4px; color: #e11d48; width: 16px; text-align: center;"></i> 
                <span style="font-size: 0.9rem; color: #475569; line-height: 1.5; white-space: pre-line;"><%= locals.settings && locals.settings.address ? locals.settings.address : 'Jalan Bhayangkara No.21, Cipocok Jaya,\nSerang, Banten - 42118' %></span>
            </div>
            
            <div style="display: flex; align-items: center; gap: 12px;">
                <i class="fas fa-phone" style="color: #2563eb; width: 16px; text-align: center;"></i> 
                <span style="font-size: 0.9rem; color: #475569;"><%= locals.settings && locals.settings.office_phone ? locals.settings.office_phone : '0877-7698-1959' %></span>
            </div>
            
            <div style="display: flex; align-items: center; gap: 12px;">
                <i class="fas fa-envelope" style="color: #64748b; width: 16px; text-align: center;"></i> 
                <span style="font-size: 0.9rem; color: #475569;"><%= locals.settings && locals.settings.office_email ? locals.settings.office_email : 'puprlab@gmail.com' %></span>
            </div>
        </div>

    </div>
</footer>