<%- include('layout/header') %>
    <%- include('layout/navbar') %>

        <header class="hero">
            <div class="container">
                <div class="hero-wrapper">

                    <div class="hero-text">
                        <span class="badge-white">LP-1676-IDN (SNI ISO/IEC 17025:2017)</span>
                        <h1>UPTD Pengujian Bahan, Konstruksi Bangunan dan Informasi Konstruksi</h1>
                        <p>Dinas Pekerjaan Umum dan Penataan Ruang Provinsi Banten.</p>
                        <p class="hero-desc">Melayani pengujian laboratorium dan lapangan yang akurat, independen, dan
                            terakreditasi untuk menjamin kualitas infrastruktur Banten.</p>

                        <a href="/login" class="btn-permohonan">
                            <i class="fas fa-edit"></i> Ajukan Permohonan
                        </a>
                    </div>

                    <div class="hero-image">
                        <img src="/img/gedung-uptd.jpeg" alt="Gedung UPTD PUPR Banten">
                        <div class="img-accent"></div>
                    </div>

                </div>
            </div>
        </header>

        <style>
            .step-card {
                cursor: pointer;
                transition: transform 0.3s ease, box-shadow 0.3s ease;
            }
            .step-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            }
            
            .modal-overlay {
                display: none; 
                position: fixed; 
                z-index: 1000; 
                left: 0;
                top: 0;
                width: 100%; 
                height: 100%; 
                background-color: rgba(0, 0, 0, 0.5); 
                backdrop-filter: blur(3px);
                align-items: center;
                justify-content: center;
                padding: 20px;
            }
            
            .modal-content {
                background-color: #fff;
                margin: auto; 
                padding: 30px;
                border-radius: 12px;
                width: 100%;
                max-width: 600px;
                max-height: 90vh;
                overflow-y: auto;
                box-shadow: 0 15px 30px rgba(0,0,0,0.2);
                position: relative;
                animation: modalFadeIn 0.3s ease;
            }

            @keyframes modalFadeIn {
                from { opacity: 0; transform: translateY(-20px); }
                to { opacity: 1; transform: translateY(0); }
            }
            
            .close-btn {
                color: #aaa;
                position: absolute;
                top: 15px;
                right: 20px;
                font-size: 28px;
                font-weight: bold;
                cursor: pointer;
            }
            
            .close-btn:hover,
            .close-btn:focus {
                color: #333;
                text-decoration: none;
            }

            .modal-title {
                color: #047857;
                margin-top: 0;
                margin-bottom: 15px;
                border-bottom: 2px solid #e2e8f0;
                padding-bottom: 10px;
            }

            .modal-body ol {
                padding-left: 20px;
                margin-top: 10px;
            }

            .modal-body li {
                margin-bottom: 8px;
                line-height: 1.5;
                color: #475569;
            }
            .modal-body p {
                color: #475569;
            }
        </style>
        <section id="layanan" class="section bg-light">
            <div class="container">
                <div class="text-center" style="padding-top: 4px;">
                    <span class="section-subtitle">Layanan Pengujian</span>
                    <h2 class="section-title">Ruang Lingkup & Tarif</h2>
                </div>

                <div class="steps-container">
                    <div class="step-card" onclick="openModal('modal-1')">
                        <div class="step-icon-box"><i class="fas fa-file-alt"></i></div>
                        <div>
                            <h5>1. Permohonan</h5>
                            <p>Isi form & bawa sampel</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="openModal('modal-2')">
                        <div class="step-icon-box"><i class="fas fa-clipboard-check"></i></div>
                        <div>
                            <h5>2. Pengecekan</h5>
                            <p>Pengecekan sampel</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="openModal('modal-3')">
                        <div class="step-icon-box"><i class="fas fa-search"></i></div>
                        <div>
                            <h5>3. Kaji Ulang</h5>
                            <p>Cek kondisi sampel</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="openModal('modal-4')">
                        <div class="step-icon-box"><i class="fas fa-wallet"></i></div>
                        <div>
                            <h5>4. Bayar</h5>
                            <p>Retribusi via Bank/QRIS</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="openModal('modal-5')">
                        <div class="step-icon-box"><i class="fas fa-flask"></i></div>
                        <div>
                            <h5>5. Pengujian</h5>
                            <p>Analisa Lab/Lapangan</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="openModal('modal-6')">
                        <div class="step-icon-box"><i class="fas fa-certificate"></i></div>
                        <div>
                            <h5>6. Selesai</h5>
                            <p>Ambil Laporan (LHU)</p>
                        </div>
                    </div>
                </div>

                <div class="cards-grid">
                    <div class="card" style="border-top: 4px solid #16a34a;">
                        <h3 style="color: #16a34a;"><i class="fas fa-check-circle"></i> Terakreditasi KAN</h3>
                        <p>Parameter yang sudah masuk ruang lingkup akreditasi:</p>
                        <ul class="check-list">
                            <% if (typeof params !=='undefined' && params.accredited) { %>
                                <% params.accredited.forEach(item=> { %>
                                    <li>
                                        <%= item %>
                                    </li>
                                    <% }) %>
                                        <% } %>
                        </ul>
                    </div>

                    <div class="card" style="border-top: 4px solid #ca8a04;">
                        <h3 style="color: #ca8a04;"><i class="fas fa-exclamation-circle"></i> Belum Terakreditasi KAN
                        </h3>
                        <p>Layanan pengujian lainnya yang tersedia (dalam proses pengembangan ruang lingkup):</p>
                        <ul class="check-list" style="color: #64748B;">
                            <% if (typeof params !=='undefined' && params.nonAccredited) { %>
                                <% params.nonAccredited.forEach(item=> { %>
                                    <li>
                                        <%= item %>
                                    </li>
                                    <% }) %>
                                        <% } %>
                        </ul>
                    </div>
                </div>

                <div class="pricing-card" style="margin-top: 40px;">
                    <h3 class="text-center mb-3">Tarif Retribusi (Sampel)</h3>
                    <table class="pricing-table">
                        <thead>
                            <tr>
                                <th>Jenis Pengujian</th>
                                <th>Satuan</th>
                                <th>Harga (Rp)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof prices !=='undefined' ) { %>
                                <% prices.forEach(item=> { %>
                                    <tr>
                                        <td>
                                            <%= item.item %>
                                        </td>
                                        <td>
                                            <%= item.unit %>
                                        </td>
                                        <td>Rp <%= item.price %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } %>
                        </tbody>
                    </table>

                    <div style="text-align: right; margin-top: 20px; padding-top: 15px; border-top: 1px solid #e2e8f0;">
                        <a href="/estimasi"
                            style="color: #2563eb; font-weight: 600; text-decoration: none; font-size: 0.95rem;">
                            Lihat Estimasi Pengujian <i class="fas fa-arrow-right" style="margin-left: 5px;"></i>
                        </a>
                    </div>
                </div>

            </div>
        </section>

        <section id="profil" class="section">
            <div class="container">
                <div class="text-center">
                    <span class="section-subtitle">Tentang Kami</span>
                    <h2 class="section-title">Sekilas Profil</h2>
                </div>

                <div class="cards-grid" style="align-items: stretch; margin-bottom: 40px;">
                    <div class="card text-center" style="padding: 40px 30px;">
                        <h3>Dinas PUPR Prov. Banten</h3>
                        <p class="mb-3 text-primary font-weight-bold">Induk Organisasi</p>
                        <p style="color: #555; line-height: 1.6;">
                            Merupakan unsur pelaksana urusan pemerintahan yang menjadi kewenangan daerah provinsi di
                            bidang pekerjaan umum dan penataan ruang.
                        </p>
                        <div style="margin-top: 20px; padding-top: 20px; border-top: 1px dashed #eee;">
                            <p style="font-size: 0.9rem; color: #888;">
                                <i class="fas fa-map-pin"></i> Kota Serang, Kawasan Pusat, Jl. Syekh Moh. Nawawi
                                Albantani, Serang Regency, Banten KP3B
                            </p>
                        </div>
                    </div>

                    <div class="card text-center" style="padding: 40px 30px;">
                        <h3>UPTD Pengujian Bahan Kontruksi Bangunan & Informasi Kontruksi</h3>
                        <p class="mb-3 text-primary font-weight-bold">Unit Pelaksana Teknis</p>
                        <p style="color: #555; line-height: 1.6;">
                            Melaksanakan kegiatan teknis operasional di bidang pengujian bahan dan konstruksi bangunan,
                            serta pengelolaan peralatan berat.
                        </p>
                        <div style="margin-top: 20px; padding-top: 20px; border-top: 1px dashed #eee;">
                            <p style="font-size: 0.9rem; color: #888;">
                                <i class="fas fa-map-pin"></i> Jalan Bhayangkara No.21, Cipocok Jaya, Serang, Banten
                            </p>
                        </div>
                    </div>
                </div>

                <div style="text-align: center;">
                    <p style="color: #64748b; margin-bottom: 20px; font-size: 1.05rem;">
                        Ingin mengetahui sejarah, struktur organisasi, dan lokasi detail kami?
                    </p>
                    <a href="/profile" class="btn-auth-base"
                        style="background: var(--primary); color: white; border: none; text-decoration: none; padding: 12px 40px; box-shadow: 0 4px 15px rgba(4, 120, 87, 0.3);">
                        Lihat Profil Lengkap & Lokasi <i class="fas fa-arrow-right" style="margin-left: 8px;"></i>
                    </a>
                </div>

            </div>
        </section>

        <!-- Modal 1: Permohonan -->
        <div id="modal-1" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-1')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-file-alt"></i> 1. Permohonan</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Proses awal pengajuan layanan pengujian oleh pemohon.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Melakukan registrasi akun dan masuk (<em>login</em>) ke dalam sistem.</li>
                        <li>Mengakses halaman <strong>Pengajuan Pengujian</strong>.</li>
                        <li>Memilih kategori serta jenis pengujian, kemudian memasukkan jumlah sampel yang akan diuji.</li>
                        <li>Melengkapi formulir pengajuan yang tersedia pada halaman sistem.</li>
                        <li>Mengunggah dokumen kelengkapan, meliputi: surat permohonan resmi dari instansi, hasil pindai (<em>scan</em>) Kartu Tanda Penduduk (KTP) yang sesuai dengan nama pemohon, serta dokumen lampiran pendukung lainnya.</li>
                        <li>Menekan tombol <strong>Kirim</strong> untuk memproses pengajuan ke dalam sistem.</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Modal 2: Pengecekan -->
        <div id="modal-2" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-2')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-clipboard-check"></i> 2. Pengecekan Sampel</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Penyerahan dan identifikasi awal sampel pengujian.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Sampel uji diserahkan secara langsung atau diantarkan ke laboratorium untuk proses identifikasi dan pencatatan awal oleh petugas.</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Modal 3: Kaji Ulang -->
        <div id="modal-3" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-3')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-search"></i> 3. Kaji Ulang</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Evaluasi teknis terhadap sampel yang diserahkan.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Petugas melakukan peninjauan dan evaluasi kondisi sampel untuk menentukan kelayakan uji berdasarkan standar operasional prosedur (SOP) yang berlaku.</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Modal 4: Bayar -->
        <div id="modal-4" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-4')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-wallet"></i> 4. Pembayaran</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Proses penyelesaian administrasi dan retribusi pengujian.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Apabila sampel dinyatakan layak uji, pemohon dapat mengakses halaman <strong>Transaksi</strong>.</li>
                        <li>Menunggu administrator mengunggah dokumen Surat Ketetapan Retribusi Daerah (SKRD).</li>
                        <li>Melakukan pembayaran retribusi sesuai dengan instruksi dan nominal yang tertera pada dokumen SKRD, kemudian mengunggah bukti pembayaran ke dalam sistem.</li>
                        <li>Administrator yang berwenang akan melakukan verifikasi dan validasi terhadap bukti pembayaran tersebut.</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Modal 5: Pengujian -->
        <div id="modal-5" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-5')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-flask"></i> 5. Pengujian</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Pelaksanaan analisa laboratorium atau lapangan.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Setelah sampel dinyatakan memenuhi kriteria kaji ulang dan proses administrasi pembayaran selesai, tim teknis akan melaksanakan proses pengujian sampel baik di laboratorium maupun di lapangan.</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Modal 6: Selesai -->
        <div id="modal-6" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-6')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-certificate"></i> 6. Selesai</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Pengambilan hasil dan penyelesaian prosedur layanan.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Pemohon mengakses kembali halaman <strong>Pengujian</strong> pada sistem.</li>
                        <li>Mengisi kuesioner evaluasi layanan (Indeks Kepuasan Masyarakat).</li>
                        <li>Mengunduh dokumen Laporan Hasil Uji (LHU) atau sertifikat pengujian elektronik yang telah dilegalisasi.</li>
                    </ol>
                </div>
            </div>
        </div>

        <script>
            function openModal(modalId) {
            document.getElementById(modalId).style.display = "flex";
                document.body.style.overflow = "hidden";
            }

            function closeModal(modalId) {
                document.getElementById(modalId).style.display = "none";
                document.body.style.overflow = "auto";
            }

            window.onclick = function(event) {
                if (event.target.classList.contains('modal-overlay')) {
                    event.target.style.display = "none";
                    document.body.style.overflow = "auto";
                }
            }
        </script>

        <%- include('layout/footer') %>