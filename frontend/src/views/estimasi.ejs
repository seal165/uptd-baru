<%- include('layout/header') %>
<header class="header-light">
    <%- include('layout/navbar', { active: 'estimasi' }) %>
</header>

<main class="estimasi-body">
    <style>
        .service-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        .detail-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 15px;
        }
        
        @media (max-width: 768px) {
            .service-grid {
                grid-template-columns: 1fr;
                gap: 12px;
            }
            .detail-grid {
                grid-template-columns: 1fr;
                gap: 12px;
            }
            .estimasi-body {
                min-height: 100vh;
                padding-bottom: 100px;
            }
            .estimasi-body .container {
                padding-top: 100px !important;
                padding-bottom: 60px !important;
                padding-left: 16px !important;
                padding-right: 16px !important;
            }
            .estimasi-body .card {
                padding: 32px 24px 50px 24px !important;
                margin: 0 0 80px 0 !important;
                min-height: 70vh;
            }
            .result-container {
                flex-direction: column !important;
                gap: 12px !important;
                padding: 16px !important;
            }
            .result-container > div {
                min-width: 100% !important;
                flex: none !important;
            }
            #totalDisplay {
                font-size: 1.4rem !important;
            }
            .btn-auth-base.btn-full {
                padding: 14px !important;
                font-size: 0.95rem !important;
            }
            .service-option {
                padding: 14px !important;
            }
            .text-center h1.section-title {
                font-size: 1.5rem !important;
            }
        }
        @media (max-width: 480px) {
            .estimasi-body .card {
                padding: 14px !important;
            }
            #totalDisplay {
                font-size: 1.2rem !important;
            }
        }
    </style>
    <section class="container" style="padding-top: 80px; padding-bottom: 80px;">
        <div class="text-center mb-5">
            <span class="section-subtitle">Simulasi Biaya</span>
            <h1 class="section-title">Hitung Estimasi Pengujian</h1>
            <p style="color: var(--secondary); max-width: 600px; margin: 0 auto;">
                Pilih jenis layanan dan tentukan jumlah sampel untuk mengetahui simulasi biaya retribusi serta estimasi waktu pengerjaan real.
            </p>
        </div>

        <div class="card" style="max-width: 800px; margin: 0 auto; padding: 40px;">
            <form id="serviceForm">
                
                <div class="mb-5">
                    <h3 class="mb-4" style="color: var(--dark); font-size: 1.1rem; font-weight: 700;">
                        1. Tipe Layanan
                    </h3>
                    <div class="service-grid">
                        <div class="service-option active" onclick="filterLayanan('PENGUJIAN BAHAN', this)">
                            <div class="icon-circle">🧱</div>
                            <h4>Bahan</h4>
                            <p style="font-size: 0.8rem; color: var(--secondary); margin: 0;">Pengujian kualitas material/bahan bangunan</p>
                        </div>
                        
                        <div class="service-option" onclick="filterLayanan('PENGUJIAN KONSTRUKSI', this)">
                            <div class="icon-circle">🏗️</div>
                            <h4>Konstruksi</h4>
                            <p style="font-size: 0.8rem; color: var(--secondary); margin: 0;">Pengujian struktur dan fisik di lapangan</p>
                        </div>
                    </div>
                </div>

                <div class="mb-5">
                    <h3 class="mb-4" style="color: var(--dark); font-size: 1.1rem; font-weight: 700;">
                        2. Detail Pengujian
                    </h3>
                    <div class="detail-grid">
                        <div class="form-group">
                            <label class="form-label">Nama Pengujian</label>
                            <div class="input-wrapper">
                                <i class="fas fa-flask icon-start"></i>
                                <select id="itemSelect" class="form-input" style="padding-left: 40px;" onchange="onItemChange()">
                                    <% if (services && services.length > 0) { 
                                        services.forEach(type => { 
                                            if (type.categories && type.categories.length > 0) { 
                                                type.categories.forEach(category => { 
                                                    if (category.items && category.items.length > 0) { 
                                    %>
                                                        <optgroup label="<%= category.categoryName %>">
                                                            <% category.items.forEach(item => { %>
                                                                <!-- 🔥 FORMAT: nama - min. xx satuan - Rp harga/satuan -->
                                                                <option value="<%= item.price %>" 
                                                                        data-type="<%= type.typeName %>"
                                                                        data-duration="<%= item.duration %>"
                                                                        data-name="<%= item.name %>"
                                                                        data-min-sample="<%= item.sample_value %>"
                                                                        data-min-sample-text="<%= item.sample_text %>"
                                                                        data-unit="<%= item.unit %>">
                                                                    <%= item.name %> - min. <%= item.sample_text %> - Rp <%= (item.price || 0).toLocaleString('id-ID') %>/<%= item.unit %>
                                                                </option>
                                                            <% }); %>
                                                        </optgroup>
                                                    <% } 
                                                }); 
                                            } 
                                        }); 
                                    } else { %>
                                        <option value="0" data-type="PENGUJIAN BAHAN" data-duration="7" data-min-sample="1" data-unit="sample">Data tidak tersedia</option>
                                    <% } %>
                                </select>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Jumlah (Qty)</label>
                            <div class="input-wrapper">
                                <i class="fas fa-calculator icon-start"></i>
                                <input type="number" id="qtyInput" class="form-input" style="padding-left: 40px;" value="1" min="1" oninput="hitungEstimasi()">
                            </div>
                            <small id="minSampleInfo" class="text-muted" style="font-size: 0.75rem; display: block; margin-top: 5px;"></small>
                        </div>
                    </div>
                </div>

                <!-- Informasi Mode Sibuk -->
                <div class="jadwal-sibuk-info" style="background: #fff3cd; border: 1px solid #ffeeba; border-radius: 8px; padding: 15px; margin-bottom: 20px; display: none;" id="jadwalSibukInfo">
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <i class="fas fa-exclamation-triangle" style="color: #856404; font-size: 1.2rem;"></i>
                        <div>
                            <strong style="color: #856404;" id="jadwalSibukTitle">Mode Sibuk Aktif</strong>
                            <p style="color: #856404; margin: 5px 0 0; font-size: 0.9rem;" id="jadwalSibukText"></p>
                        </div>
                    </div>
                </div>

                <div class="result-container" style="background: #f8fafc; padding: 25px; border-radius: 12px; border: 1px solid var(--border); display: flex; flex-wrap: wrap; gap: 20px; margin-bottom: 30px;">
                    <div style="flex: 1; min-width: 200px;">
                        <p style="font-size: 0.85rem; color: var(--secondary); margin-bottom: 5px; font-weight: 600;">Total Estimasi Biaya:</p>
                        <h2 id="totalDisplay" class="price-tag" style="margin: 0; font-size: 1.8rem;">Rp 0</h2>
                    </div>
                    <div style="flex: 1; min-width: 200px;">
                        <p style="font-size: 0.85rem; color: var(--secondary); margin-bottom: 5px; font-weight: 600;">Estimasi Waktu Pengerjaan:</p>
                        <h4 id="timeDisplay" style="margin: 0; color: var(--dark); font-weight: 700;">-</h4>
                    </div>
                    <div style="flex: 1; min-width: 200px;">
                        <p style="font-size: 0.85rem; color: var(--secondary); margin-bottom: 5px; font-weight: 600;">Estimasi Selesai:</p>
                        <h4 id="finishDateDisplay" style="margin: 0; color: #16a34a; font-weight: 700;">-</h4>
                    </div>
                </div>

                <button type="button" onclick="location.href='/login'" class="btn-auth-base btn-full btn-primary">
                    Lanjutkan ke Pendaftaran <i class="fas fa-arrow-right" style="margin-left: 8px;"></i>
                </button>
            </form>
        </div>
    </section>
</main>

<script>
    // ==================== DATA INISIALISASI ====================
    let modeSibuk = {
        active: false,
        periods: []
    };
    
    // Hari libur nasional
    const hariLibur = [
        '01-01', // Tahun Baru
        '05-01', // Hari Buruh
        '08-17', // Kemerdekaan
        '12-25', // Natal
    ];

    // ==================== LOAD DATA MODE SIBUK ====================
    async function loadModeSibuk() {
        try {
            const API_URL = (window.__APP_CONFIG__ && window.__APP_CONFIG__.apiUrl) || '/api';
            const response = await fetch(`${API_URL}/public/busy-schedule`);
            const result = await response.json();
            if (result.success) {
                const payload = result.data;
                modeSibuk = {
                    active: payload.active || false,
                    periods: payload.data || []
                };
                console.log('✅ Mode sibuk loaded:', modeSibuk);
                hitungEstimasi();
            } else {
                console.warn('⚠️ Mode sibuk API response not success:', result);
            }
        } catch (error) {
            console.error('❌ Error loading mode sibuk:', error);
        }
    }

    // ==================== FUNGSI HELPER ====================
    
    // Fungsi untuk mengecek apakah hari libur
    function isHariLibur(date) {
        const day = date.getDay();
        const month = ('0' + (date.getMonth() + 1)).slice(-2);
        const dayOfMonth = ('0' + date.getDate()).slice(-2);
        const monthDay = month + '-' + dayOfMonth;
        return day === 0 || day === 6 || hariLibur.includes(monthDay);
    }

    // Fungsi untuk menambah hari kerja (skip weekend dan libur)
    function addWorkingDays(startDate, days) {
        let result = new Date(startDate);
        let addedDays = 0;
        
        while (addedDays < days) {
            result.setDate(result.getDate() + 1);
            if (!isHariLibur(result)) {
                addedDays++;
            }
        }
        return result;
    }

    // Fungsi untuk mendapatkan tanggal mulai berdasarkan mode sibuk
    function getStartDate() {
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        
        if (!modeSibuk.active || modeSibuk.periods.length === 0) {
            return addWorkingDays(today, 1);
        }
        
        let lastSibukDate = new Date(today);
        modeSibuk.periods.forEach(periode => {
            const selesai = new Date(periode.tanggal_selesai);
            if (selesai > lastSibukDate) {
                lastSibukDate = selesai;
            }
        });
        
        if (lastSibukDate >= today) {
            const nextDay = new Date(lastSibukDate);
            nextDay.setDate(nextDay.getDate() + 1);
            return addWorkingDays(nextDay, 1);
        } else {
            return addWorkingDays(today, 1);
        }
    }

    // Fungsi untuk mengkonversi string durasi ke hari
    function parseDurasi(durasiStr) {
        if (!durasiStr) return 7;
        const match = durasiStr.match(/\d+/);
        if (match) {
            return parseInt(match[0]) || 7;
        }
        return 7;
    }

    // Fungsi untuk menghitung estimasi selesai
    function hitungEstimasiSelesai(tanggalMulai, durasiHari) {
        let currentDate = new Date(tanggalMulai);
        let sisaHari = durasiHari;
        
        while (sisaHari > 0) {
            currentDate.setDate(currentDate.getDate() + 1);
            if (isHariLibur(currentDate)) {
                continue;
            }
            sisaHari--;
        }
        return currentDate;
    }

    // ==================== FUNGSI UTAMA ====================
    
    function onItemChange() {
        const select = document.getElementById('itemSelect');
        const selectedOption = select.options[select.selectedIndex];
        
        let minSample = parseInt(selectedOption.getAttribute('data-min-sample')) || 1;
        const minSampleText = selectedOption.getAttribute('data-min-sample-text') || minSample + ' sample';
        const unit = selectedOption.getAttribute('data-unit') || 'sample';
        
        const qtyInput = document.getElementById('qtyInput');
        if (qtyInput) {
            qtyInput.min = minSample;
            qtyInput.value = minSample;
            
            const minSampleInfo = document.getElementById('minSampleInfo');
            if (minSampleInfo) {
                minSampleInfo.innerHTML = `Minimal: ${minSampleText}`;
            }
        }
        
        hitungEstimasi();
    }
    
    function hitungEstimasi() {
        const select = document.getElementById('itemSelect');
        const qty = parseInt(document.getElementById('qtyInput').value) || 1;
        
        if (!select || select.selectedIndex === -1) {
            return;
        }
        
        const selectedOption = select.options[select.selectedIndex];
        const price = parseInt(selectedOption.value) || 0;
        const durasiStr = selectedOption?.getAttribute('data-duration') || "7";
        const minSample = parseInt(selectedOption.getAttribute('data-min-sample')) || 1;
        const unit = selectedOption.getAttribute('data-unit') || 'sample';
        const itemName = selectedOption?.text || '';
        
        const finalQty = Math.max(qty, minSample);
        if (qty < minSample) {
            document.getElementById('qtyInput').value = minSample;
        }
        
        const total = price * finalQty;
        const durasiHari = parseDurasi(durasiStr);
        const startDate = getStartDate();
        const finishDate = hitungEstimasiSelesai(startDate, durasiHari);
        
        const options = { day: 'numeric', month: 'long', year: 'numeric' };
        const startDateStr = startDate.toLocaleDateString('id-ID', options);
        const finishDateStr = finishDate.toLocaleDateString('id-ID', options);
        
        // Tampilkan info mode sibuk
        const jadwalInfo = document.getElementById('jadwalSibukInfo');
        const jadwalText = document.getElementById('jadwalSibukText');
        const jadwalTitle = document.getElementById('jadwalSibukTitle');
        
        if (jadwalInfo && jadwalText && jadwalTitle) {
            if (modeSibuk.active && modeSibuk.periods.length > 0) {
                let lastPeriod = modeSibuk.periods[0];
                modeSibuk.periods.forEach(p => {
                    if (new Date(p.tanggal_selesai) > new Date(lastPeriod.tanggal_selesai)) {
                        lastPeriod = p;
                    }
                });
                
                const selesaiDate = new Date(lastPeriod.tanggal_selesai);
                const selesaiStr = selesaiDate.toLocaleDateString('id-ID', options);
                
                jadwalInfo.style.display = 'block';
                jadwalTitle.innerHTML = '⚠️ Mode Sibuk Aktif';
                jadwalText.innerHTML = `Laboratorium sedang dalam periode sibuk sampai ${selesaiStr}. Estimasi pengerjaan akan dimulai setelah periode sibuk berakhir.`;
            } else {
                jadwalInfo.style.display = 'none';
            }
        }
        
        document.getElementById('totalDisplay').innerText = 'Rp ' + total.toLocaleString('id-ID');
        document.getElementById('timeDisplay').innerHTML = durasiHari + ' hari kerja';
        document.getElementById('finishDateDisplay').innerText = finishDateStr;
        
        try {
            sessionStorage.setItem('estimasi_total', total);
            sessionStorage.setItem('estimasi_durasi', durasiHari);
            sessionStorage.setItem('estimasi_mulai', startDateStr);
            sessionStorage.setItem('estimasi_selesai', finishDateStr);
            sessionStorage.setItem('estimasi_item', selectedOption?.text || '');
            sessionStorage.setItem('estimasi_qty', finalQty);
            sessionStorage.setItem('estimasi_unit', unit);
        } catch (e) {
            console.log('Session storage error:', e);
        }
    }

    function filterLayanan(type, element) {
        document.querySelectorAll('.service-option').forEach(el => el.classList.remove('active'));
        element.classList.add('active');

        const select = document.getElementById('itemSelect');
        const options = select.querySelectorAll('option');
        const optgroups = select.querySelectorAll('optgroup');
        
        let firstVisibleSet = false;
        let visibleCount = 0;

        if (type === 'SEMUA') {
            options.forEach(opt => {
                opt.style.display = '';
                opt.disabled = false;
                visibleCount++;
                if (!firstVisibleSet) {
                    opt.selected = true;
                    firstVisibleSet = true;
                }
            });
            optgroups.forEach(group => {
                group.style.display = 'block';
            });
        } else {
            options.forEach(opt => {
                const optType = opt.getAttribute('data-type');
                if (optType === type) {
                    opt.style.display = '';
                    opt.disabled = false;
                    visibleCount++;
                    if (!firstVisibleSet) {
                        opt.selected = true;
                        firstVisibleSet = true;
                    }
                } else {
                    opt.style.display = 'none';
                    opt.disabled = true;
                }
            });

            optgroups.forEach(group => {
                const hasVisible = Array.from(group.querySelectorAll('option')).some(opt => opt.style.display !== 'none');
                group.style.display = hasVisible ? 'block' : 'none';
            });
        }
        
        onItemChange();
    }

    // ==================== INISIALISASI ====================
    
    window.addEventListener('DOMContentLoaded', () => {
        console.log('🚀 Page loaded');
        
        loadModeSibuk();
        
        const select = document.getElementById('itemSelect');
        const options = select.querySelectorAll('option');
        const optgroups = select.querySelectorAll('optgroup');
        
        options.forEach(opt => {
            opt.style.display = '';
            opt.disabled = false;
        });
        
        optgroups.forEach(group => {
            group.style.display = 'block';
        });
        
        if (options.length > 0) {
            options[0].selected = true;
        }
        
        onItemChange();
        hitungEstimasi();
    });
</script>



<%- include('layout/footer') %>