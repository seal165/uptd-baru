<%# views/user/profile.ejs %>
<% 
const title = 'Profil Saya - UPTD Lab';
const currentPage = 'profile';
const pageTitle = 'Profil Saya';
const user = locals.user || {};
const notificationCount = locals.notificationCount || 0;
const assetBaseUrl = (locals.appConfig && locals.appConfig.assetBaseUrl) || '';
const profileAvatarSrc = user.avatar
    ? (user.avatar.startsWith('http') ? user.avatar : `${assetBaseUrl}${user.avatar}`)
    : '';
%>

<%- include('partials/header', { title }) %>
<%- include('partials/sidebar', { currentPage, user }) %>

<main class="main-content">
    <%- include('partials/top-navbar', { pageTitle, user, notificationCount }) %>

    <div class="content-body">
    <!-- Profile Content -->
    <div class="profile-container">
        <!-- Profile Header -->
        <div class="profile-header">
            <div class="profile-cover">
                <div class="profile-cover-content">
                    <div class="profile-avatar-column">
                        <div class="profile-avatar-wrapper">
                            <div class="profile-avatar" id="profileAvatar">
                                <% if (profileAvatarSrc) { %>
                                    <img src="<%= profileAvatarSrc %>" alt="Profile" class="profile-avatar-image"
                                         onerror="this.style.display='none'; document.getElementById('avatarInitials').style.display='flex'">
                                    <div class="avatar-initials" id="avatarInitials" style="display:none;">
                                        <%= (user.full_name || user.name || 'U').split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2) %>
                                    </div>
                                <% } else { %>
                                    <div class="avatar-initials" id="avatarInitials">
                                        <%= (user.full_name || user.name || 'U').split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2) %>
                                    </div>
                                <% } %>
                            </div>
                            <button class="btn-change-photo" id="changePhotoBtn" type="button" aria-label="Ubah foto profil">
                                <i class="fas fa-camera"></i>
                            </button>
                        </div>
                    </div>

                    <div class="profile-identity">
                        <span class="profile-eyebrow">Akun Pengguna</span>
                        <h2 id="profileDisplayName"><%= user.full_name || user.name || 'User' %></h2>
                        <p id="profileDisplayRole"><%= user.role || 'Customer' %></p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Profile Content Grid -->
        <div class="profile-grid">
            <!-- Left Column - Personal Information -->
            <div class="profile-card">
                <div class="profile-card-header">
                    <h3><i class="fas fa-user"></i> Informasi Pribadi</h3>
                    <button class="btn-edit" id="editPersonalBtn" type="button">
                        Edit
                    </button>
                </div>
                
                <div class="profile-card-body">
                    <div class="profile-info-group">
                        <label>Nama Lengkap</label>
                        <p id="displayName"><%= user.full_name || '-' %></p>
                    </div>
                    
                    <div class="profile-info-group">
                        <label>Email (tidak dapat diubah)</label>
                        <p id="displayEmail"><%= user.email || '-' %></p>
                    </div>
                    
                    <div class="profile-info-group">
                        <label>Nomor Telepon</label>
                        <p id="displayPhone"><%= user.nomor_telepon || '-' %></p>
                    </div>
                </div>
            </div>
            
            <!-- Right Column - Company Information -->
            <div class="profile-card">
                <div class="profile-card-header">
                    <h3><i class="fas fa-building"></i> Informasi Instansi</h3>
                    <button class="btn-edit" id="editCompanyBtn" type="button">
                        Edit
                    </button>
                </div>
                
                <div class="profile-card-body">
                    <div class="profile-info-group">
                        <label>Nama Perusahaan / Instansi</label>
                        <p id="displayCompany"><%= user.nama_instansi || '-' %></p>
                    </div>
                    
                    <div class="profile-info-group">
                        <label>Alamat Instansi</label>
                        <p id="displayAddress"><%= user.alamat || '-' %></p>
                    </div>
                </div>
            </div>
            
            <!-- Account Settings -->
            <div class="profile-card full-width">
                <div class="profile-card-header">
                    <h3><i class="fas fa-shield-alt"></i> Pengaturan Akun</h3>
                </div>
                
                <div class="profile-card-body">
                    <div class="settings-grid">
                        <!-- Ubah Password (tetap) -->
                        <div class="profile-setting-item">
                            <div class="profile-setting-info">
                                <strong>Ubah Password</strong>
                                <p>Perbarui password secara berkala untuk keamanan akun</p>
                            </div>
                            <button class="btn-setting" id="changePasswordBtn" type="button">
                                Ubah
                            </button>
                        </div>
                        
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Edit Personal Modal -->
    <div class="edit-modal" id="editPersonalModal">
        <div class="edit-modal-content">
            <div class="profile-modal-header">
                <h3><i class="fas fa-user-edit"></i> Edit Informasi Pribadi</h3>
                <button class="btn-close-modal" id="closePersonalModal" type="button" aria-label="Tutup modal edit informasi pribadi">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div class="profile-modal-body">
                <form id="personalForm">
                    <div class="form-group">
                        <label for="editName">Nama Lengkap <span class="required">*</span></label>
                        <input type="text" id="editName" class="form-control" value="<%= user.full_name || '' %>" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="editEmail">Email (Tidak Dapat Diubah) <span class="required">*</span></label>
                        <input type="email" id="editEmail" class="form-control" value="<%= user.email || '' %>" required readonly>
                    </div>
                    
                    <div class="form-group">
                        <label for="editPhone">Nomor Telepon</label>
                        <input type="tel" id="editPhone" class="form-control" value="<%= user.nomor_telepon || '' %>" placeholder="08xxxxxxxxxx">
                    </div>
                </form>
            </div>
            
            <div class="profile-modal-footer">
                <button class="btn-cancel" id="cancelPersonalBtn" type="button">Batal</button>
                <button class="btn-save" id="savePersonalBtn" type="button">
                    Simpan Perubahan
                </button>
            </div>
        </div>
    </div>
    
    <!-- Edit Company Modal -->
    <div class="edit-modal" id="editCompanyModal">
        <div class="edit-modal-content">
            <div class="profile-modal-header">
                <h3><i class="fas fa-building"></i> Edit Informasi Instansi</h3>
                <button class="btn-close-modal" id="closeCompanyModal" type="button" aria-label="Tutup modal edit informasi instansi">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div class="profile-modal-body">
                <form id="companyForm">
                    <div class="form-group">
                        <label for="editCompany">Nama Perusahaan / Instansi</label>
                        <input type="text" id="editCompany" class="form-control" value="<%= user.nama_instansi || '' %>">
                    </div>
                    
                    <div class="form-group">
                        <label for="editAddress">Alamat Instansi</label>
                        <textarea id="editAddress" class="form-control" rows="3"><%= user.alamat || '' %></textarea>
                    </div>
                </form>
            </div>
            
            <div class="profile-modal-footer">
                <button class="btn-cancel" id="cancelCompanyBtn" type="button">Batal</button>
                <button class="btn-save" id="saveCompanyBtn" type="button">
                    Simpan Perubahan
                </button>
            </div>
        </div>
    </div>
    
    <!-- Change Password Modal -->
    <div class="edit-modal" id="changePasswordModal">
        <div class="edit-modal-content">
            <div class="profile-modal-header">
                <h3><i class="fas fa-key"></i> Ubah Password</h3>
                <button class="btn-close-modal" id="closePasswordModal" type="button" aria-label="Tutup modal ubah password">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div class="profile-modal-body">
                <form id="passwordForm">
                    <div class="form-group">
                        <label for="currentPassword">Password Saat Ini <span class="required">*</span></label>
                        <input type="password" id="currentPassword" class="form-control" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="newPassword">Password Baru <span class="required">*</span></label>
                        <input type="password" id="newPassword" class="form-control" required>
                        <small class="form-text">Minimal 6 karakter</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="confirmPassword">Konfirmasi Password Baru <span class="required">*</span></label>
                        <input type="password" id="confirmPassword" class="form-control" required>
                    </div>
                </form>
            </div>
            
            <div class="profile-modal-footer">
                <button class="btn-cancel" id="cancelPasswordBtn" type="button">Batal</button>
                <button class="btn-save" id="savePasswordBtn" type="button">
                    Ubah Password
                </button>
            </div>
        </div>
    </div>
    
    <!-- Change Photo Modal -->
    <div class="edit-modal" id="changePhotoModal">
        <div class="edit-modal-content">
            <div class="profile-modal-header">
                <h3><i class="fas fa-camera"></i> Ubah Foto Profil</h3>
                <button class="btn-close-modal" id="closePhotoModal" type="button" aria-label="Tutup modal ubah foto profil">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div class="profile-modal-body text-center">
                <div class="current-photo-preview" id="photoPreview">
                    <% if (profileAvatarSrc) { %>
                        <img src="<%= profileAvatarSrc %>" alt="Profile" class="profile-current-photo-image"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
                        <div class="avatar-initials" style="display:none; width:100px; height:100px; font-size:2rem; border-radius:50%;">
                            <%= (user.full_name || user.name || 'U').split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2) %>
                        </div>
                    <% } else { %>
                        <div class="avatar-initials" style="width:100px; height:100px; font-size:2rem; border-radius:50%;">
                            <%= (user.full_name || user.name || 'U').split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2) %>
                        </div>
                    <% } %>
                </div>
                
                <div class="profile-upload-area" id="uploadArea">
                    <i class="fas fa-cloud-upload-alt"></i>
                    <p>Klik atau seret file ke sini untuk upload</p>
                    <small>Format: JPG, PNG (Maks. 2MB)</small>
                    <input type="file" id="photoUpload" class="profile-file-input" accept="image/*">
                </div>
                
                <div class="photo-preview" id="imagePreview" hidden>
                    <img id="previewImage" src="" alt="Preview">
                </div>
            </div>
            
            <div class="profile-modal-footer">
                <button class="btn-cancel" id="cancelPhotoBtn" type="button">Batal</button>
                <button class="btn-save" id="savePhotoBtn" type="button" disabled>
                    Simpan
                </button>
            </div>
        </div>
    </div>
    
    <!-- Toast Notification -->
    <div class="custom-toast" id="toast" hidden></div>
    
    <!-- Data container (will be populated by JS) -->
    <div id="user-data-container" hidden></div>
    </div>

    <script src="/js/user/profile.js"></script>

</main>
<%- include('partials/footer') %>