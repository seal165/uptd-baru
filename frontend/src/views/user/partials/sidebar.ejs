<%# views/user/partials/sidebar.ejs %>
<div id="sidebarOverlay" class="sidebar-overlay"></div>
<aside class="sidebar">
    <div class="sidebar-inner">
        <div class="logo-section">
            <h1 class="logo-title">UPTD PBKBIK</h1>
            <p class="logo-subtitle">Provinsi Banten</p>
        </div>
        
        <nav class="main-menu">
            <ul>
                <li class="menu-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
                    <a href="/user/dashboard" class="menu-link">
                        <i class="fas fa-tachometer-alt menu-icon"></i>
                        <span class="menu-text">Beranda</span>
                    </a>
                </li>
                <li class="menu-item <%= currentPage === 'submission' ? 'active' : '' %>">
                    <a href="/user/submission" class="menu-link">
                        <i class="fas fa-file-alt menu-icon"></i>
                        <span class="menu-text">Pengajuan</span>
                    </a>
                </li>
                <li class="menu-item <%= currentPage === 'history' ? 'active' : '' %>">
                    <a href="/user/history" class="menu-link">
                        <i class="fas fa-history menu-icon"></i>
                        <span class="menu-text">Riwayat</span>
                    </a>
                </li>
                <li class="menu-item <%= currentPage === 'transaction' ? 'active' : '' %>">
                    <a href="/user/transaction" class="menu-link">
                        <i class="fas fa-exchange-alt menu-icon"></i>
                        <span class="menu-text">Transaksi</span>
                    </a>
                </li>
                </ul>
        </nav>
        
        <div class="sidebar-footer">
            <a href="/user/profile" class="user-profile-sidebar <%= currentPage === 'profile' ? 'active' : '' %>" style="text-decoration: none; display: flex; align-items: center; width: 100%; transition: all 0.3s;">
                <div class="user-avatar-sidebar">
                    <% if (user?.avatar) { %>
                        <img src="<%= user.avatar.startsWith('http') ? user.avatar : ((typeof backendUrl !== 'undefined' ? backendUrl : 'http://localhost:5000') + user.avatar) %>" alt="Avatar" class="avatar-image" />
                    <% } else { %>
                        <i class="fas fa-user-circle"></i>
                    <% } %>
                </div>
                <div class="user-info-sidebar">
                    <h4 style="margin: 0;"><%= user?.full_name || user?.name || 'User' %></h4>
                    <p style="margin: 0;"><%= user?.role || 'Customer' %></p>
                </div>
                <i class="fas fa-chevron-right" style="margin-left: auto; font-size: 0.8rem; opacity: 0.5;"></i>
            </a>

            <button class="logout-btn" id="logoutBtn">
                <i class="fas fa-sign-out-alt"></i>
                <span>Log Out</span>
            </button>
        </div>
    </div>
</aside>