<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'UPTD Pengujian Bahan Konstruksi Bangunan & Informasi Konstruksi' %></title>
    
    <link rel="icon" type="image/png" href="/img/logo.png">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- 🔥 BOOTSTRAP CSS (WAJIB UNTUK DASHBOARD) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <!-- 🔥 USER STYLES (WAJIB UNTUK DASHBOARD USER) -->
    <link rel="stylesheet" href="/css/user-style.css?v=25">

    <!-- Settings & Config dari server via data attribute untuk mencegah linter error -->
    <div id="serverData" 
         data-settings='<%- JSON.stringify(locals.settings || {}).replace(/&apos;/g, "\\'") %>' 
         data-config='<%- JSON.stringify(locals.appConfig || {}).replace(/&apos;/g, "\\'") %>' 
         style="display:none;"></div>
    <script>
        (function() {
            try {
                var el = document.getElementById('serverData');
                if (el) {
                    window.settings = JSON.parse(el.getAttribute('data-settings') || '{}');
                    window.__APP_CONFIG__ = JSON.parse(el.getAttribute('data-config') || '{}');
                } else {
                    window.settings = {};
                    window.__APP_CONFIG__ = {};
                }
            } catch (e) {
                console.warn('Config parse error:', e);
                window.settings = {};
                window.__APP_CONFIG__ = {};
            }
        })();
    </script>
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body>
<div class="app-wrapper">