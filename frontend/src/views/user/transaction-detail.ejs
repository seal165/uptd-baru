<%# views/user/transaction-detail.ejs %>
<% 
const title = 'Detail Transaksi - UPTD Lab';
const currentPage = 'transaction';
const pageTitle = 'Detail Transaksi';
const user = locals.user || {};
const notificationCount = locals.notificationCount || 0;
const transactionId = locals.id || '';
%>

<style>
/* ===== TRANSACTION DETAIL LAYOUT ===== */
.transaction-detail-container {
    max-width: 860px;
    margin: 0 auto;
}
.transaction-detail-card {
    background: white;
    border-radius: 14px;
    border: 1px solid #e9edf2;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    overflow: hidden;
}

/* === HEADER === */
.detail-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 24px 28px;
    background: #f8fafc;
    border-bottom: 1px solid #e9edf2;
    gap: 12px;
}
.detail-header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 4px 0;
}
.detail-header .text-muted { font-size: 0.875rem; color: #64748b; margin: 0; }

/* === SECTION === */
.info-section {
    padding: 20px 28px;
    border-bottom: 1px solid #f1f4f9;
}
.info-section:last-child { border-bottom: none; }
.info-section h4 {
    font-size: 0.9rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 14px 0;
    display: flex;
    align-items: center;
    gap: 8px;
}
.info-section h4 i { color: #4361ee; }

/* === INFO GRID === */
.info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
}
.info-item label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 4px;
}
.info-item p {
    font-size: 0.9rem;
    color: #1e293b;
    font-weight: 500;
    margin: 0;
    word-break: break-word;
}

/* === PAYMENT DETAIL === */
.payment-detail-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
}
.payment-item label {
    font-size: 0.72rem;
    font-weight: 600;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 4px;
}
.payment-item p { margin: 0; font-size: 0.9rem; color: #1e293b; font-weight: 500; }
.payment-item .amount { font-size: 1.05rem; font-weight: 700; }
.payment-item .paid { color: #16a34a; }
.payment-item .remaining { color: #dc2626; }

/* === SERVICE DETAIL === */
.service-detail {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
}
.service-item label {
    font-size: 0.72rem;
    font-weight: 600;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 4px;
}
.service-item p { margin: 0; font-size: 0.9rem; color: #1e293b; font-weight: 500; }

/* === STATUS BADGE === */
.status-badge {
    display: inline-block;
    padding: 5px 14px;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 600;
    white-space: nowrap;
}
.status-lunas               { background: #d1fae5; color: #065f46; }
.status-belum-lunas         { background: #fee2e2; color: #991b1b; }
.status-belum-bayar         { background: #fef3c7; color: #92400e; }
.status-menunggu-skrd       { background: #fef3c7; color: #92400e; }
.status-sedang-diuji        { background: #dbeafe; color: #1e40af; }
.status-selesai             { background: #d1fae5; color: #065f46; }
.status-dibatalkan          { background: #f1f5f9; color: #475569; }
.status-menunggu-verifikasi { background: #fef3c7; color: #92400e; }
.status-pengecekan-sampel   { background: #dbeafe; color: #1e40af; }
.status-default             { background: #f1f5f9; color: #475569; }

/* === SKRD & PROOF === */
.skrd-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    padding: 14px 16px;
    background: #f8fafc;
    border-radius: 10px;
    border: 1px solid #e9edf2;
}
.proof-container { display: flex; flex-direction: column; gap: 12px; }

/* === UPLOAD AREA === */
.upload-area {
    border: 2px dashed #e2e8f0;
    border-radius: 10px;
    padding: 32px 16px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s;
}
.upload-area:hover { border-color: #4361ee; }

/* === NOTES === */
.notes-text {
    background: #fef3c7;
    border-left: 4px solid #f59e0b;
    padding: 12px 16px;
    border-radius: 0 8px 8px 0;
    font-size: 0.875rem;
    color: #92400e;
    margin: 0;
}

/* === TOAST === */
.custom-toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: #0f172a;
    color: white;
    padding: 12px 20px;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 500;
    z-index: 9999;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
}

/* ===== MOBILE RESPONSIVE ===== */
@media (max-width: 768px) {
    .detail-header {
        flex-direction: column;
        padding: 16px 18px;
        gap: 10px;
    }
    .detail-header h2 { font-size: 1.05rem; }

    .info-section { padding: 16px 18px; }
    .info-section h4 { font-size: 0.85rem; margin-bottom: 10px; }

    .info-grid {
        grid-template-columns: 1fr;
        gap: 10px;
    }
    .payment-detail-grid {
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }
    .service-detail {
        grid-template-columns: 1fr;
        gap: 10px;
    }

    .skrd-section {
        flex-direction: column;
        align-items: flex-start;
    }
    .skrd-section .skrd-action {
        width: 100%;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }
    .skrd-section .skrd-action .btn,
    .skrd-section .skrd-action a {
        flex: 1;
        text-align: center;
        justify-content: center;
    }

    /* Upload form */
    .d-flex.gap-2 {
        flex-direction: column;
    }
    .d-flex.gap-2 .btn {
        width: 100%;
    }

    .custom-toast {
        left: 16px;
        right: 16px;
        bottom: 16px;
    }
}

@media (max-width: 480px) {
    .payment-detail-grid { grid-template-columns: 1fr; }
    .payment-item .amount { font-size: 0.95rem; }
    .status-badge { font-size: 0.7rem; padding: 4px 10px; }
}
</style>

<%- include('partials/header', { title }) %>
<%- include('partials/sidebar', { currentPage, user }) %>

<main class="main-content">
    <%- include('partials/top-navbar', { pageTitle, user, notificationCount }) %>
    
    <div class="content-body">
        <!-- Data dari backend disimpan di atribut data -->
        <div id="transaction-detail-data" 
             data-id="<%= transactionId %>"
             data-user='<%- JSON.stringify(user).replace(/'/g, "\\'") %>'
             style="display: none;"></div>
        
        <!-- Loading State -->
        <div id="loadingState" class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Memuat detail transaksi...</p>
    </div>
    
    <!-- Error State -->
    <div id="errorState" style="display: none;" class="text-center py-5">
        <i class="fas fa-exclamation-circle text-danger fa-3x mb-3"></i>
        <h5>Gagal Memuat Data</h5>
        <p class="text-muted" id="errorMessage">Terjadi kesalahan saat memuat data</p>
        <a href="/user/transaction" class="btn btn-primary mt-3">Kembali ke Transaksi</a>
    </div>
    
    <!-- Content State -->
    <div id="contentState" style="display: none;" class="transaction-detail-container">
        <div class="transaction-detail-card">
            <!-- Header -->
            <div class="detail-header">
                <div class="header-left">
                    <h2>Invoice <span id="invoice-number">#INV-001</span></h2>
                    <p class="text-muted" id="invoice-date">-</p>
                </div>
                <div class="header-right">
                    <span class="status-badge" id="invoice-status">-</span>
                </div>
            </div>
            
            <!-- Info Perusahaan -->
            <div class="info-section">
                <h4><i class="fas fa-building"></i> Informasi Perusahaan</h4>
                <div class="info-grid">
                    <div class="info-item">
                        <label>Nama Perusahaan</label>
                        <p id="company-name">-</p>
                    </div>
                    <div class="info-item">
                        <label>Nama Pemohon</label>
                        <p id="applicant-name">-</p>
                    </div>
                    <div class="info-item">
                        <label>Email</label>
                        <p id="applicant-email">-</p>
                    </div>
                    <div class="info-item">
                        <label>Telepon</label>
                        <p id="applicant-phone">-</p>
                    </div>
                </div>
            </div>
            
            <!-- Detail Pembayaran -->
            <div class="info-section">
                <h4><i class="fas fa-credit-card"></i> Detail Pembayaran</h4>
                <div class="payment-detail-grid">
                    <div class="payment-item">
                        <label>Total Tagihan</label>
                        <p class="amount" id="total-amount">Rp 0</p>
                    </div>
                    <div class="payment-item">
                        <label>Sudah Dibayar</label>
                        <p class="amount paid" id="paid-amount">Rp 0</p>
                    </div>
                    <div class="payment-item">
                        <label>Sisa Tagihan</label>
                        <p class="amount remaining" id="remaining-amount">Rp 0</p>
                    </div>
                    <!-- HAPUS Metode Pembayaran -->
                    <!-- <div class="payment-item">
                        <label>Metode Pembayaran</label>
                        <p id="payment-method">-</p>
                    </div> -->
                    <div class="payment-item">
                        <label>Tanggal Bayar</label>
                        <p id="payment-date">-</p>
                    </div>
                    <!-- HAPUS No. VA -->
                    <!-- <div class="payment-item">
                        <label>No. VA</label>
                        <p id="va-number">-</p>
                    </div> -->
                </div>
            </div>
            
            <!-- Detail Layanan -->
            <div class="info-section">
                <h4><i class="fas fa-flask"></i> Detail Layanan</h4>
                <div class="service-detail">
                    <div class="service-item">
                        <label>No. Permohonan</label>
                        <p id="service-code">-</p>
                    </div>
                    <div class="service-item">
                        <label>Nama Layanan</label>
                        <p id="service-name">-</p>
                    </div>
                    <div class="service-item">
                        <label>Jumlah</label>
                        <p id="service-qty">-</p>
                    </div>
                    <div class="service-item">
                        <label>Harga Satuan</label>
                        <p id="service-price">Rp 0</p>
                    </div>
                </div>
            </div>
            
            <!-- SKRD Section -->
            <div class="info-section">
                <h4><i class="fas fa-file-invoice"></i> Dokumen SKRD</h4>
                <div class="skrd-section" id="skrd-section">
                    <div class="skrd-info" id="skrd-info">
                        <p class="text-muted">Memuat informasi SKRD...</p>
                    </div>
                    <div class="skrd-action" id="skrd-action">
                        <!-- Akan diisi JavaScript -->
                    </div>
                </div>
            </div>
            
            <!-- Bukti Pembayaran Section -->
            <div class="info-section" id="proof-section" style="display: none;">
                <h4><i class="fas fa-receipt"></i> Bukti Pembayaran</h4>
                <div id="proof-container" class="proof-container">
                    <!-- Akan diisi JavaScript dengan kedua bukti pembayaran -->
                </div>
            </div>

            <!-- Form Upload Bukti Pembayaran -->
            <div id="upload-proof-section" style="display: none;" class="mt-4 p-4 border rounded bg-light">
                <h5 class="mb-3" id="upload-title"><i class="fas fa-cloud-upload-alt text-primary me-2"></i>Upload Bukti Pembayaran</h5>
                <p class="text-muted mb-3" id="upload-description"></p>
                
                <form id="uploadProofForm" enctype="multipart/form-data">
                    <input type="hidden" id="transactionId" value="<%= transactionId %>">
                    
                    <!-- Bagian upload form - perbaiki struktur preview -->
                    <div class="mb-3">
                        <label for="proofFile" class="form-label fw-bold">Pilih File Bukti Pembayaran</label>
                        <div class="upload-area" id="uploadArea">
                            <i class="fas fa-cloud-upload-alt fa-3x mb-3 text-primary"></i>
                            <p class="mb-2">Klik atau drag & drop file di sini</p>
                            <p class="text-muted small">Format: JPG, PNG, PDF (Maks 2MB)</p>
                            <input type="file" class="form-control d-none" id="proofFile" name="payment_proof" accept=".jpg,.jpeg,.png,.pdf" required>
                        </div>
                        
                        <!-- Preview area yang lebih informatif -->
                        <div id="filePreview" class="mt-3 p-3 bg-white rounded border" style="display: none;">
                            <div class="d-flex align-items-center gap-3">
                                <i class="fas fa-file-pdf text-danger fa-2x" id="fileIcon"></i>
                                <div class="flex-grow-1">
                                    <div class="fw-bold" id="fileName"></div>
                                    <div class="text-muted small" id="fileSize"></div>
                                    <div class="text-muted small" id="fileType"></div>
                                </div>
                                <button type="button" class="btn btn-sm btn-light" onclick="removeFile()">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="paymentNotes" class="form-label fw-bold">Catatan (opsional)</label>
                        <textarea class="form-control" id="paymentNotes" rows="2" placeholder="Tambahkan catatan tentang pembayaran..."></textarea>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" id="submitProofBtn">
                            Upload Bukti
                        </button>
                        <button type="button" class="btn btn-light" onclick="cancelUpload()">
                            Batal
                        </button>
                    </div>
                </form>
            </div>

            <!-- Tombol untuk menampilkan form upload -->
            <div id="show-upload-btn" style="display: none;" class="mt-3">
                <button class="btn btn-outline-primary" onclick="showUploadForm()">
                    Upload Bukti Pembayaran
                </button>
            </div>
            
            <!-- Catatan -->
            <div class="info-section" id="notes-section" style="display: none;">
                <h4><i class="fas fa-sticky-note"></i> Catatan</h4>
                <p id="payment-notes" class="notes-text"></p>
            </div>
        </div>
    </div>
    </div>
    
<div class="custom-toast" id="toast" style="display: none;"></div>

<script src="/js/user/transaction-detail.js"></script>

</main>
<%- include('partials/footer') %>