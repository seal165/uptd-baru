<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - UPTD Lab</title>
    <link rel="icon" type="image/png" href="/img/logo.png">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body class="login-body">

    <div class="login-card register-card">

        <!-- Header -->
        <div class="auth-icon-wrapper">
            <img src="/img/logo-banten.png" alt="Logo Banten" style="width: 100%; height: auto;">
        </div>
        <h2 class="auth-title">UPTD Pengujian</h2>
        <p class="auth-subtitle">Bahan Konstruksi Bangunan &amp; Informasi Konstruksi</p>

        <!-- Tabs -->
        <div class="auth-tabs">
            <a href="/login" class="auth-tab">Login</a>
            <a href="/register" class="auth-tab active">Register</a>
        </div>

        <!-- Alert: Error -->
        <% if (locals.error) { %>
            <div class="alert-box alert-error">
                <i class="fas fa-exclamation-circle"></i>
                <span><%= error %></span>
            </div>
        <% } %>

        <!-- Alert: Success -->
        <% if (locals.success) { %>
            <div class="alert-box alert-success">
                <i class="fas fa-check-circle"></i>
                <span><%= success %></span>
            </div>
        <% } %>

        <!-- Form -->
        <form action="/auth/register" method="POST">

            <!-- ===== Personal Information ===== -->
            <div class="form-section-label">
                <i class="fas fa-user" style="margin-right: 6px; color: var(--primary);"></i>
                Informasi Pribadi
            </div>

            <!-- Nama Lengkap -->
            <div class="form-group">
                <label class="form-label">Nama Lengkap <span class="req">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-user icon-start"></i>
                    <input
                        type="text"
                        name="full_name"
                        class="form-input"
                        placeholder="Nama lengkap penanggung jawab"
                        required
                        value="<%= locals.formData ? formData.full_name : '' %>">
                </div>
                <p class="field-hint">Nama lengkap penanggung jawab / kontak person</p>
            </div>

            <!-- Email -->
            <div class="form-group">
                <label class="form-label">Email Address <span class="req">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope icon-start"></i>
                    <input
                        type="email"
                        name="email"
                        class="form-input"
                        placeholder="name@company.com"
                        required
                        value="<%= locals.formData ? formData.email : '' %>">
                </div>
            </div>

            <!-- Password -->
            <div class="form-group">
                <label class="form-label">Password <span class="req">*</span></label>
                <div class="input-wrapper has-icon-end">
                    <i class="fas fa-lock icon-start"></i>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        class="form-input"
                        placeholder="Minimal 6 karakter"
                        required
                        minlength="6">
                    <i class="fas fa-eye-slash icon-end" onclick="togglePassword(this)"></i>
                </div>
                <p class="field-hint">Minimal 6 karakter</p>
            </div>

            <!-- Konfirmasi Password -->
            <div class="form-group">
                <label class="form-label">Konfirmasi Password <span class="req">*</span></label>
                <div class="input-wrapper has-icon-end">
                    <i class="fas fa-lock icon-start"></i>
                    <input
                        type="password"
                        id="confirm_password"
                        name="confirm_password"
                        class="form-input"
                        placeholder="Ketik ulang password"
                        required
                        minlength="6">
                    <i class="fas fa-eye-slash icon-end" onclick="togglePassword(this)"></i>
                </div>
            </div>

            <!-- ===== Company Information ===== -->
            <div class="form-section-label" style="margin-top: 18px;">
                <i class="fas fa-building" style="margin-right: 6px; color: var(--primary);"></i>
                Informasi Instansi
            </div>

            <!-- Nama Instansi -->
            <div class="form-group">
                <label class="form-label">Nama Instansi/Perusahaan <span class="req">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-building icon-start"></i>
                    <input
                        type="text"
                        name="nama_instansi"
                        class="form-input"
                        placeholder="Contoh: PT. Konstruksi Maju"
                        required
                        value="<%= locals.formData ? formData.nama_instansi : '' %>">
                </div>
            </div>

            <!-- Alamat -->
            <div class="form-group">
                <label class="form-label">Alamat Instansi <span class="req">*</span></label>
                <div class="input-wrapper textarea-wrapper">
                    <i class="fas fa-map-marker-alt icon-start"></i>
                    <textarea
                        name="alamat"
                        class="form-textarea"
                        placeholder="Alamat lengkap perusahaan"
                        required
                        rows="3"><%= locals.formData ? formData.alamat : '' %></textarea>
                </div>
            </div>

            <!-- Nomor Telepon -->
            <div class="form-group">
                <label class="form-label">Nomor Telepon <span class="req">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-phone icon-start"></i>
                    <input
                        type="tel"
                        name="nomor_telepon"
                        class="form-input"
                        placeholder="Contoh: 081234567890"
                        required
                        value="<%= locals.formData ? formData.nomor_telepon : '' %>">
                </div>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-auth-base btn-action-register btn-full">
                Buat Akun
            </button>

            <!-- Terms -->
            <p class="terms-text" style="margin-top: 14px;">
                Dengan mendaftar, Anda menyetujui
                <a href="/terms">Syarat &amp; Ketentuan</a> yang berlaku.
            </p>

            <!-- Footer -->
            <p class="terms-text" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #eef2f6;">
                © 2026 UPTD Pengujian Bahan Konstruksi Bangunan Provinsi Banten.
            </p>

        </form>
    </div>

    <script>
        function togglePassword(icon) {
            const input = icon.previousElementSibling;
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            }
        }

        document.querySelector('form').addEventListener('submit', function (e) {
            const password = document.getElementById('password').value;
            const confirm  = document.getElementById('confirm_password').value;

            if (password.length < 6) {
                e.preventDefault();
                showInlineAlert('error', 'Password minimal 6 karakter!');
                return;
            }
            if (password !== confirm) {
                e.preventDefault();
                showInlineAlert('error', 'Password dan konfirmasi password tidak cocok!');
            }
        });

        function showInlineAlert(type, message) {
            const existing = document.querySelector('.alert-box.js-alert');
            if (existing) existing.remove();

            const div = document.createElement('div');
            div.className = `alert-box alert-${type} js-alert`;
            const icon = type === 'error' ? 'fa-exclamation-circle' : 'fa-check-circle';
            div.innerHTML = `<i class="fas ${icon}"></i><span>${message}</span>`;

            const form = document.querySelector('form');
            form.insertAdjacentElement('beforebegin', div);
            div.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    </script>

</body>
</html>