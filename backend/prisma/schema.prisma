generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model activities {
  id            Int       @id @default(autoincrement())
  user_id       Int?
  activity_name String?   @db.VarChar(255)
  ip_address    String?   @db.VarChar(45)
  user_agent    String?   @db.Text
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  users         users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "activities_ibfk_1")

  @@index([user_id], map: "user_id")
}

model jadwal_sibuk {
  id              Int       @id @default(autoincrement())
  keterangan      String    @db.VarChar(255)
  tanggal_mulai   DateTime  @db.Date
  tanggal_selesai DateTime  @db.Date
  created_at      DateTime? @default(now()) @db.Timestamp(0)
  updated_at      DateTime? @default(now()) @db.Timestamp(0)
  created_by      Int?
  updated_by      Int?

  @@index([tanggal_mulai, tanggal_selesai], map: "idx_tanggal")
}

model kuisioner {
  id              Int         @id @default(autoincrement())
  submission_id   Int         @unique(map: "submission_id")
  saran           String?     @db.Text
  jawaban_json    Json?
  pertanyaan_json Json?
  created_at      DateTime?   @default(now()) @db.Timestamp(0)
  submissions     submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "kuisioner_ibfk_1")
}

model kuisioner_questions {
  id            Int    @id @default(autoincrement())
  question_text String @db.Text
  urutan        Int?   @default(0)
}

model notifications {
  id         Int       @id @default(autoincrement())
  user_id    Int
  title      String    @db.VarChar(255)
  message    String    @db.Text
  href       String?   @default("#") @db.VarChar(255)
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(0)
}

model payments {
  id                             Int                         @id @default(autoincrement())
  submission_id                  Int                         @unique(map: "submission_id")
  no_invoice                     String                      @db.VarChar(100)
  total_tagihan                  Decimal?                    @default(0.00) @db.Decimal(15, 2)
  jumlah_dibayar                 Decimal?                    @default(0.00) @db.Decimal(15, 2)
  sisa_tagihan                   Decimal?                    @db.Decimal(15, 2)
  status_pembayaran              payments_status_pembayaran? @default(Belum_Bayar)
  bukti_pembayaran_1             String?                     @db.VarChar(255)
  bukti_pembayaran_2             String?                     @db.VarChar(255)
  bukti_pembayaran_1_uploaded_at DateTime?                   @db.DateTime(0)
  bukti_pembayaran_2_uploaded_at DateTime?                   @db.DateTime(0)
  skrd_file                      String?                     @db.VarChar(255)
  skrd_filename                  String?                     @db.VarChar(255)
  skrd_uploaded_at               DateTime?                   @db.DateTime(0)
  skrd_uploaded_by               Int?
  bukti_pembayaran_notes         String?                     @db.Text
  created_at                     DateTime?                   @default(now()) @db.Timestamp(0)
  updated_at                     DateTime?                   @default(now()) @db.Timestamp(0)
  submissions                    submissions                 @relation(fields: [submission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "payments_ibfk_1")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model services {
  id                 Int                  @id @default(autoincrement())
  category_id        Int
  test_type_id       Int
  service_name       String               @db.VarChar(255)
  min_sample         String?              @db.VarChar(100)
  satuan             String?              @default("sample") @db.VarChar(50)
  duration_days      Int?
  price              Decimal              @default(0.00) @db.Decimal(15, 2)
  method             String?              @db.VarChar(255)
  kan                services_kan?        @default(Tidak)
  created_at         DateTime?            @default(now()) @db.Timestamp(0)
  test_types         test_types           @relation(fields: [test_type_id], references: [id], onUpdate: NoAction, map: "fk_services_test_type")
  test_categories    test_categories      @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "services_ibfk_1")
  submission_samples submission_samples[]

  @@index([category_id], map: "category_id")
  @@index([test_type_id], map: "idx_test_type_id")
}

model settings {
  id            Int       @id @default(autoincrement())
  setting_key   String    @unique(map: "setting_key") @db.VarChar(100)
  setting_value String?   @db.Text
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @default(now()) @db.Timestamp(0)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model submission_samples {
  id                    Int                                      @id @default(autoincrement())
  submission_id         Int
  jenis_sample          String?                                  @db.VarChar(255)
  nama_identitas_sample String?                                  @db.VarChar(255)
  jumlah_sample_angka   Int                                      @default(1)
  jumlah_sample_satuan  submission_samples_jumlah_sample_satuan? @default(sample)
  tanggal_pengambilan   DateTime?                                @db.Date
  kemasan_sample        String?                                  @db.VarChar(100)
  asal_sample           String?                                  @db.VarChar(255)
  sample_diambil_oleh   submission_samples_sample_diambil_oleh?  @default(Pelanggan)
  test_type_id          Int
  test_category_id      Int
  service_id            Int
  price_at_time         Decimal                                  @db.Decimal(15, 2)
  method_at_time        String?                                  @db.VarChar(255)
  estimasi_selesai      DateTime?                                @db.Date
  created_at            DateTime?                                @default(now()) @db.Timestamp(0)
  submissions           submissions                              @relation(fields: [submission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "submission_samples_ibfk_1")
  test_types            test_types                               @relation(fields: [test_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "submission_samples_ibfk_2")
  test_categories       test_categories                          @relation(fields: [test_category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "submission_samples_ibfk_3")
  services              services                                 @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "submission_samples_ibfk_4")

  @@index([service_id], map: "service_id")
  @@index([submission_id], map: "submission_id")
  @@index([test_category_id], map: "test_category_id")
  @@index([test_type_id], map: "test_type_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model submissions {
  id                    Int                  @id @default(autoincrement())
  user_id               Int
  no_permohonan         String?              @db.VarChar(100)
  nama_pemohon          String               @db.VarChar(255)
  nama_instansi         String?              @db.VarChar(255)
  alamat_pemohon        String?              @db.Text
  nomor_telepon         String?              @db.VarChar(20)
  email_pemohon         String?              @db.VarChar(100)
  nama_proyek           String               @db.VarChar(255)
  lokasi_proyek         String?              @db.VarChar(255)
  file_surat_permohonan String?              @db.VarChar(255)
  file_ktp              String?              @db.VarChar(255)
  dokumen_tambahan      String?              @db.Text
  catatan_tambahan      String?              @db.VarChar(250)
  catatan_admin         String?              @db.Text
  jadwal_sampling       DateTime?            @db.Date
  status                submissions_status?  @default(Menunggu_Verifikasi)
  created_at            DateTime?            @default(now()) @db.Timestamp(0)
  updated_at            DateTime?            @default(now()) @db.Timestamp(0)
  kuisioner             kuisioner?
  payments              payments?
  submission_samples    submission_samples[]
  users                 users                @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "submissions_ibfk_1")
  test_reports          test_reports?

  @@index([jadwal_sampling], map: "idx_jadwal_sampling")
  @@index([user_id], map: "user_id")
}

model test_categories {
  id                 Int                  @id @default(autoincrement())
  test_type_id       Int
  category_name      String               @db.VarChar(100)
  created_at         DateTime?            @default(now()) @db.Timestamp(0)
  services           services[]
  submission_samples submission_samples[]
  test_types         test_types           @relation(fields: [test_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "test_categories_ibfk_1")

  @@index([test_type_id], map: "test_type_id")
}

model test_reports {
  id              Int         @id @default(autoincrement())
  submission_id   Int         @unique(map: "submission_id")
  file_laporan    String?     @db.VarChar(255)
  no_laporan      String?     @db.VarChar(100)
  tanggal_selesai DateTime?   @db.Date
  catatan_laporan String?     @db.Text
  created_at      DateTime?   @default(now()) @db.Timestamp(0)
  submissions     submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "test_reports_ibfk_1")
}

model test_types {
  id                 Int                  @id @default(autoincrement())
  type_name          String               @db.VarChar(100)
  created_at         DateTime?            @default(now()) @db.Timestamp(0)
  services           services[]
  submission_samples submission_samples[]
  test_categories    test_categories[]
}

model user_notifications {
  id         Int       @id @default(autoincrement())
  user_id    Int
  title      String    @db.VarChar(255)
  message    String    @db.Text
  type       String?   @default("info") @db.VarChar(50)
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_notifications_ibfk_1")

  @@index([user_id], map: "user_id")
}

model users {
  id                 Int                  @id @default(autoincrement())
  email              String               @unique(map: "email") @db.VarChar(100)
  password           String               @db.VarChar(255)
  role               users_role?          @default(pelanggan)
  full_name          String               @db.VarChar(100)
  nama_instansi      String?              @db.VarChar(255)
  alamat             String?              @db.Text
  nomor_telepon      String?              @db.VarChar(20)
  avatar             String?              @db.VarChar(255)
  created_at         DateTime?            @default(now()) @db.Timestamp(0)
  updated_at         DateTime?            @db.Timestamp(0)
  notif_email        Boolean?             @default(true)
  notif_wa           Boolean?             @default(false)
  activities         activities[]
  submissions        submissions[]
  user_notifications user_notifications[]
}

enum users_role {
  admin
  petugas
  pelanggan
}

enum submission_samples_jumlah_sample_satuan {
  Buah
  Kilogram
  sample
  Titik
  Liter
  Meter
}

enum payments_status_pembayaran {
  Menunggu_Verifikasi  @map("Menunggu Verifikasi")
  Pengecekan_Sampel    @map("Pengecekan Sampel")
  Belum_Bayar          @map("Belum Bayar")
  Menunggu_SKRD_Upload @map("Menunggu SKRD Upload")
  Belum_Lunas          @map("Belum Lunas")
  Lunas
  Sedang_Diuji         @map("Sedang Diuji")
  Selesai
  Dibatalkan
}

enum services_kan {
  Ya
  Tidak
}

enum submission_samples_sample_diambil_oleh {
  Pelanggan
  Laboratorium
  Pihak_Ketiga @map("Pihak Ketiga")
}

enum submissions_status {
  Menunggu_Verifikasi  @map("Menunggu Verifikasi")
  Pengecekan_Sampel    @map("Pengecekan Sampel")
  Belum_Bayar          @map("Belum Bayar")
  Menunggu_SKRD_Upload @map("Menunggu SKRD Upload")
  Belum_Lunas          @map("Belum Lunas")
  Lunas
  Sedang_Diuji         @map("Sedang Diuji")
  Selesai
  Dibatalkan
}
