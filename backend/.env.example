NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000

# CORS - pisah pakai koma, JANGAN pakai *
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=uptd_lab
DB_PORT=3306
DATABASE_URL="mysql://root:@localhost:3306/uptd_lab"

# JWT - WAJIB GANTI dengan hasil "openssl rand -hex 64"
JWT_ACCESS_SECRET=ganti_dengan_hasil_openssl_rand_hex_64_pertama_minimal_32_char
JWT_REFRESH_SECRET=ganti_dengan_hasil_openssl_rand_hex_64_kedua_minimal_32_char
JWT_ACCESS_EXPIRES=3h
JWT_REFRESH_EXPIRES=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Mail (opsional, kalau pakai notifikasi email)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=

# Upload limit (MB)
MAX_UPLOAD_SIZE_MB=5

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
