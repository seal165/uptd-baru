{
  "env": { "node": true, "es2022": true },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "commonjs"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_|^next$" }],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-empty": ["warn", { "allowEmptyCatch": true }]
  }
}
